---
import Layout from '../layouts/Layout.astro';

const configs = [
  {
    number: "01",
    id: "hpc-24",
    name: "HPC-24",
    series: "HPC",
    cpu: "AMD Ryzen 9950X",
    cpuSub: "16C / 32T",
    memory: "256GB DDR5",
    storage: "2× 4TB NVMe SSD",
    network: "Dual 10Gbps",
    bandwidth: "1Gbps Unmetered",
    price: 659,
  },
  {
    number: "02",
    id: "hpc-22",
    name: "HPC-22",
    series: "HPC",
    cpu: "AMD Ryzen 9950X",
    cpuSub: "16C / 32T",
    memory: "192GB DDR5",
    storage: "2× 4TB NVMe SSD",
    network: "Dual 10Gbps",
    bandwidth: "1Gbps Unmetered",
    price: 579,
  },
  {
    number: "03",
    id: "hpc-18",
    name: "HPC-18",
    series: "HPC",
    cpu: "AMD Ryzen 9900X",
    cpuSub: "12C / 24T",
    memory: "192GB DDR5",
    storage: "2× 4TB NVMe SSD",
    network: "Dual 10Gbps",
    bandwidth: "1Gbps Unmetered",
    price: 549,
  },
  {
    number: "04",
    id: "evc-12",
    name: "EVC-12",
    series: "EVC",
    cpu: "Dual Intel Gold 6138",
    cpuSub: "40C / 80T",
    memory: "512GB DDR4",
    storage: "8× 1TB SSD RAID",
    network: "Dual 10Gbps",
    bandwidth: "1Gbps 95th Percentile",
    price: 719,
  },
];
---

<Layout
  title="Dedicated Servers | Nelexa"
  description="HPC and EVC bare-metal dedicated servers in Dallas and New York. AMD Ryzen 9000-series and dual-socket Intel Xeon configurations with dual 10Gbps networking."
  structuredData={{ type: 'service', data: { service: { type: 'Dedicated Server Hosting', name: 'Nelexa Dedicated Servers', description: 'Enterprise bare-metal dedicated servers in Dallas and New York.' } } }}
>
  <!-- Hero -->
  <section class="relative pt-36 pb-20 bg-black overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-primary-800/25 rounded-full blur-[140px] pointer-events-none"></div>
    <div class="absolute inset-0 grid-bg opacity-30"></div>
    <div class="container mx-auto relative z-10">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-white/10 bg-white/[0.03] text-xs font-medium text-white/70">
          Dedicated Servers
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter text-white mb-6">
          Bare-metal, <span class="gradient-text italic">built for scale.</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 max-w-3xl leading-relaxed">
          Purpose-engineered HPC and EVC platforms in Dallas and New York. Dedicated cores, dedicated RAM, dedicated network — no noisy neighbors, no hypervisor tax, no excuses.
        </p>
      </div>
    </div>
  </section>

  <!-- Configurations -->
  <section id="hpc" class="relative py-20 bg-black">
    <div class="container mx-auto">
      <div class="max-w-3xl mb-12">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-white mb-4">Available Servers</h2>
        <p class="text-white/60">Configurations available in both Dallas (DFW) and New York (NYC). Need something different? <a href="/hardware" class="text-primary-400 hover:text-primary-300 underline">We'll build it.</a></p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {configs.map((c) => (
          <div id={c.id} class:list={["group relative glass-card p-8 hover:border-primary-500/50 transition-colors duration-300 overflow-hidden", c.series === "EVC" && "scroll-mt-24"]}>
            <div class="absolute inset-0 bg-gradient-to-br from-primary-600/0 to-primary-600/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            
            <div class="relative z-10">
              <div class="flex items-start justify-between mb-6">
                <div>
                  <div class="font-mono text-xs text-primary-400 tracking-widest mb-2">{c.number}</div>
                  <h3 class="text-3xl font-bold text-white tracking-tight">{c.name}</h3>
                  <div class="mt-2 flex items-center gap-2 text-xs text-white/50">
                    <span class="inline-flex items-center gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-primary-400"></span>
                      NYC
                    </span>
                    <span class="text-white/20">·</span>
                    <span class="inline-flex items-center gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-primary-400"></span>
                      Dallas
                    </span>
                  </div>
                </div>
                <div class="text-right">
                  <div class="text-4xl font-bold text-white">${c.price}</div>
                  <div class="text-xs text-white/40">/month</div>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4 py-6 border-t border-white/10">
                <div>
                  <div class="text-xs uppercase tracking-wider text-white/40 mb-1">CPU</div>
                  <div class="text-sm font-semibold text-white">{c.cpu}</div>
                  <div class="text-xs text-white/50">{c.cpuSub}</div>
                </div>
                <div>
                  <div class="text-xs uppercase tracking-wider text-white/40 mb-1">Memory</div>
                  <div class="text-sm font-semibold text-white">{c.memory}</div>
                </div>
                <div>
                  <div class="text-xs uppercase tracking-wider text-white/40 mb-1">Storage</div>
                  <div class="text-sm font-semibold text-white">{c.storage}</div>
                </div>
                <div>
                  <div class="text-xs uppercase tracking-wider text-white/40 mb-1">Network</div>
                  <div class="text-sm font-semibold text-white">{c.network}</div>
                  <div class="text-xs text-white/50">{c.bandwidth}</div>
                </div>
              </div>

              <a href="/contact" class="inline-flex items-center gap-2 text-sm text-primary-400 hover:text-primary-300 font-semibold mt-4 transition-colors">
                Order {c.name}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="evc" class="relative py-20 bg-black border-t border-white/5 scroll-mt-24">
    <div class="container mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="glass-card p-8">
          <div class="w-11 h-11 rounded-lg bg-primary-600/20 border border-primary-500/30 flex items-center justify-center mb-4">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-300"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Rapid Provisioning</h3>
          <p class="text-sm text-white/60 leading-relaxed">Standard configurations deploy within hours. Custom builds in days, not weeks — because we do the hardware sourcing in-house.</p>
        </div>

        <div class="glass-card p-8">
          <div class="w-11 h-11 rounded-lg bg-primary-600/20 border border-primary-500/30 flex items-center justify-center mb-4">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-300"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">99.99% SLA</h3>
          <p class="text-sm text-white/60 leading-relaxed">Redundant power, redundant networking, and 24/7 on-site remote hands backed by a meaningful SLA — not the one everyone else has.</p>
        </div>

        <div class="glass-card p-8">
          <div class="w-11 h-11 rounded-lg bg-primary-600/20 border border-primary-500/30 flex items-center justify-center mb-4">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-300"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Senior Engineers</h3>
          <p class="text-sm text-white/60 leading-relaxed">When you open a ticket, it goes to someone who understands IPMI, BGP, and why your workload is different from everybody else's.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 bg-black">
    <div class="container mx-auto">
      <div class="relative glass-card overflow-hidden p-10 md:p-14 text-center">
        <div class="absolute inset-0 bg-gradient-to-br from-primary-600/15 to-accent-700/10"></div>
        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-bold tracking-tighter text-white mb-4">Don't see what you need?</h2>
          <p class="text-lg text-white/70 mb-8 max-w-2xl mx-auto">We build custom configurations every day. Tell us what you need — cores, memory, drives, accelerators — and we'll spec and deliver it.</p>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-primary-600 hover:bg-primary-500 text-white font-semibold rounded-lg transition-colors shadow-xl shadow-primary-900/40">
            Contact Sales
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
