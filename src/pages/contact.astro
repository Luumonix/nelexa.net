---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Sales | Nelexa"
  description="Talk to a real engineer about dedicated servers, colocation, hardware solutions, or IP transit. Nelexa sales responds within one business day."
>
  <!-- Hero -->
  <section class="relative pt-36 pb-12 bg-black overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[400px] bg-primary-800/25 rounded-full blur-[140px] pointer-events-none"></div>
    <div class="absolute inset-0 grid-bg opacity-30"></div>
    <div class="container mx-auto relative z-10">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-white/10 bg-white/[0.03] text-xs font-medium text-white/70">
          Contact Sales
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter text-white mb-6">
          Let's <span class="gradient-text italic">build something.</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 max-w-3xl leading-relaxed">
          Reach our sales engineers directly. Typical response time is under one business day — and the person who replies will actually be able to scope your project.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Panel -->
  <section class="relative py-16 bg-black">
    <div class="container mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
        <!-- Form -->
        <div class="lg:col-span-3 glass-card p-8 md:p-10">
          <h2 class="text-2xl font-semibold text-white mb-2">Tell us about your project</h2>
          <p class="text-white/60 text-sm mb-8">No forms in triplicate. Just enough context to quote you accurately.</p>

          <form action="mailto:sales@nelexa.net" method="post" enctype="text/plain" class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs uppercase tracking-wider text-white/60 mb-2">Name</label>
                <input required type="text" name="name" class="w-full px-4 py-3 rounded-lg bg-white/[0.03] border border-white/10 text-white placeholder:text-white/30 focus:border-primary-500 focus:outline-none" placeholder="Your name" />
              </div>
              <div>
                <label class="block text-xs uppercase tracking-wider text-white/60 mb-2">Company</label>
                <input type="text" name="company" class="w-full px-4 py-3 rounded-lg bg-white/[0.03] border border-white/10 text-white placeholder:text-white/30 focus:border-primary-500 focus:outline-none" placeholder="Company name" />
              </div>
            </div>

            <div>
              <label class="block text-xs uppercase tracking-wider text-white/60 mb-2">Email</label>
              <input required type="email" name="email" class="w-full px-4 py-3 rounded-lg bg-white/[0.03] border border-white/10 text-white placeholder:text-white/30 focus:border-primary-500 focus:outline-none" placeholder="you@company.com" />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs uppercase tracking-wider text-white/60 mb-2">Service of Interest</label>
                <select name="service" class="w-full px-4 py-3 rounded-lg bg-white/[0.03] border border-white/10 text-white focus:border-primary-500 focus:outline-none appearance-none">
                  <option value="" class="bg-black">Select a service</option>
                  <option value="dedicated" class="bg-black">Dedicated Servers</option>
                  <option value="colocation" class="bg-black">Colocation</option>
                  <option value="hardware" class="bg-black">Hardware Solutions</option>
                  <option value="ip-transit" class="bg-black">IP Transit</option>
                  <option value="other" class="bg-black">Multiple / Other</option>
                </select>
              </div>
              <div>
                <label class="block text-xs uppercase tracking-wider text-white/60 mb-2">Preferred Location</label>
                <select name="location" class="w-full px-4 py-3 rounded-lg bg-white/[0.03] border border-white/10 text-white focus:border-primary-500 focus:outline-none appearance-none">
                  <option value="" class="bg-black">No preference</option>
                  <option value="dallas" class="bg-black">Dallas, TX</option>
                  <option value="nyc" class="bg-black">New York, NY</option>
                  <option value="both" class="bg-black">Both / Multi-region</option>
                </select>
              </div>
            </div>

            <div>
              <label class="block text-xs uppercase tracking-wider text-white/60 mb-2">How can we help?</label>
              <textarea required rows="5" name="message" class="w-full px-4 py-3 rounded-lg bg-white/[0.03] border border-white/10 text-white placeholder:text-white/30 focus:border-primary-500 focus:outline-none resize-none" placeholder="Configurations, quantities, timeline, context — whatever helps us scope this accurately."></textarea>
            </div>

            <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-primary-600 hover:bg-primary-500 text-white font-semibold rounded-lg transition-colors shadow-xl shadow-primary-900/40">
              Send to Sales
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="lg:col-span-2 space-y-4">
          <div class="glass-card p-6">
            <div class="text-xs uppercase tracking-wider text-white/50 mb-2">Sales Email</div>
            <a href="mailto:sales@nelexa.net" class="text-lg text-white hover:text-primary-300 font-medium transition-colors">sales@nelexa.net</a>
            <p class="text-xs text-white/50 mt-2">Under one business day response.</p>
          </div>

          <div class="glass-card p-6">
            <div class="text-xs uppercase tracking-wider text-white/50 mb-3">Data Centers</div>
            <div class="space-y-3">
              <a href="/locations/dallas" class="flex items-center gap-3 group">
                <div class="w-9 h-9 rounded-lg bg-primary-600/20 border border-primary-500/30 flex items-center justify-center flex-shrink-0">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-300"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold text-white group-hover:text-primary-200 transition-colors">Dallas, TX</div>
                  <div class="text-xs text-white/50">DFW Metroplex</div>
                </div>
              </a>
              <a href="/locations/new-york" class="flex items-center gap-3 group">
                <div class="w-9 h-9 rounded-lg bg-primary-600/20 border border-primary-500/30 flex items-center justify-center flex-shrink-0">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-300"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold text-white group-hover:text-primary-200 transition-colors">New York, NY</div>
                  <div class="text-xs text-white/50">NYC Metro</div>
                </div>
              </a>
            </div>
          </div>

          <div class="glass-card p-6">
            <div class="text-xs uppercase tracking-wider text-white/50 mb-3">Community</div>
            <a href="https://discord.gg/nelexa" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 group">
              <div class="w-9 h-9 rounded-lg bg-primary-600/20 border border-primary-500/30 flex items-center justify-center flex-shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-primary-300"><path d="M20.317 4.369a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.249a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.249.077.077 0 00-.079-.037 19.736 19.736 0 00-4.885 1.515.07.07 0 00-.032.027C.533 9.045-.32 13.58.099 18.057a.082.082 0 00.031.056 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028 14.09 14.09 0 001.226-1.994.076.076 0 00-.041-.105 13.098 13.098 0 01-1.872-.892.077.077 0 01-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 01.077-.01c3.927 1.793 8.18 1.793 12.061 0a.074.074 0 01.078.009c.12.099.246.198.372.292a.077.077 0 01-.006.127 12.3 12.3 0 01-1.873.892.077.077 0 00-.041.106c.36.699.772 1.363 1.225 1.993a.076.076 0 00.084.028 19.84 19.84 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.548-13.66a.061.061 0 00-.031-.028zM8.02 15.331c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.418 2.157-2.418 1.21 0 2.176 1.095 2.157 2.418 0 1.334-.956 2.419-2.157 2.419zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.418 2.157-2.418 1.21 0 2.176 1.095 2.157 2.418 0 1.334-.946 2.419-2.157 2.419z"/></svg>
              </div>
              <div>
                <div class="text-sm font-semibold text-white group-hover:text-primary-200 transition-colors">Discord</div>
                <div class="text-xs text-white/50">Join our community</div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
