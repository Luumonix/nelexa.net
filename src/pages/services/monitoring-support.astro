---
import Layout from '../../layouts/Layout.astro';
import ComingSoon from '../../components/services/ComingSoon.astro';
import Breadcrumbs from '../../components/SEO/Breadcrumbs.astro';

const breadcrumbs = [
	{ name: 'Home', url: '/' },
	{ name: 'Services', url: '/services' },
	{ name: 'Monitoring & Support', url: '/services/monitoring-support' }
];
---

<Layout title="Monitoring & Support Services - Coming Soon">
	<div class="container mx-auto px-4 pt-6">
		<Breadcrumbs items={breadcrumbs} />
	</div>
	<ComingSoon 
		serviceName="Monitoring & Support"
		description="24/7 system monitoring and expert technical support. We'll watch your infrastructure round the clock and fix issues before they impact your business."
		launchDate="Q1 2026"
	/>
</Layout>
