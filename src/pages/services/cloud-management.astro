---
import Layout from '../../layouts/Layout.astro';
import ComingSoon from '../../components/services/ComingSoon.astro';
import Breadcrumbs from '../../components/SEO/Breadcrumbs.astro';

const breadcrumbs = [
	{ name: 'Home', url: '/' },
	{ name: 'Services', url: '/services' },
	{ name: 'Cloud Management', url: '/services/cloud-management' }
];
---

<Layout title="Cloud Management Services - Coming Soon">
	<div class="container mx-auto px-4 pt-6">
		<Breadcrumbs items={breadcrumbs} />
	</div>
	<ComingSoon 
		serviceName="Cloud Management"
		description="Expert cloud platform optimization and cost reduction. We'll manage your AWS, Azure, or hybrid infrastructure while cutting your bills by up to 60%."
		launchDate="Q1 2026"
	/>
</Layout>
