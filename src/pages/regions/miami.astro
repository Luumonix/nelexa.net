---
import Layout from '@/layouts/Layout.astro';
import RegionOverview from '@/components/regions/RegionOverview.astro';
import Breadcrumbs from '@/components/SEO/Breadcrumbs.astro';
import { getRegionBySlug } from '@/data/regions';

const region = getRegionBySlug('miami');

if (!region) {
  return Astro.redirect('/404');
}

const locationData = {
  city: "Miami",
  state: "FL",
  country: "US",
  postalCode: "33166",
  slug: "miami",
  coordinates: {
    lat: 25.7617,
    lng: -80.1918
  },
  description: "Hurricane-rated datacenter in Miami providing VPS hosting, dedicated servers, colocation, and managed IT services. Ideal gateway for Latin American connectivity and disaster-resistant infrastructure.",
  image: region.hero.image
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Regions', url: '/regions' },
  { name: 'Miami', url: '/regions/miami' }
];
---

<Layout 
  title={`Miami VPS & Colocation - ${region.facility} Datacenter | Charged IT Solutions`}
  description="Miami datacenter with VPS starting at $5/mo, dedicated servers, and colocation from $70/mo. Located at 365 Datacenters BC1 with hurricane-rated infrastructure. Perfect for Miami businesses and Latin American connectivity."
  keywords="Miami VPS, Miami colocation, Miami datacenter, Miami dedicated servers, Miami managed services, Miami cloud hosting, Miami web hosting, Florida VPS, Florida colocation, Miami IT services, Miami disaster recovery, Miami DDoS protection, 365 Datacenters Miami, Miami server hosting, Latin America connectivity"
  structuredData={{
    type: 'localbusiness',
    data: { location: locationData }
  }}
>
  <RegionOverview region={region} breadcrumbs={breadcrumbs} />
</Layout>
