---
import Layout from '../layouts/Layout.astro';
import HomelabHero from '../components/audience/HomelabHero.astro';
import HomelabFeatures from '../components/audience/HomelabFeatures.astro';
import CallToAction from '../components/colocation/CallToAction.astro';
import Breadcrumbs from '../components/SEO/Breadcrumbs.astro';

const breadcrumbs = [
	{ name: 'Home', url: '/' },
	{ name: 'For Homelabbers', url: '/for-homelabbers' }
];

const serviceData = {
	type: "Homelab Hosting Solutions",
	name: "VPS & Colocation for Homelab Enthusiasts",
	description: "Professional hosting solutions for homelab enthusiasts. From affordable VPS to colocation for your hardware. Perfect for learning, testing, and running personal projects 24/7."
};
---

<Layout 
	title="Homelab Hosting - VPS & Colocation for Homelab Enthusiasts | From $5/mo"
	description="Professional hosting for homelabbers. Affordable VPS starting at $5/mo, 1U colocation from $70/mo. Perfect for Proxmox, pfSense, TrueNAS, Docker, and more. 24/7 uptime for your homelab projects."
	keywords="homelab hosting, homelab VPS, homelab colocation, homelab server hosting, VPS for homelab, colocation for homelab, Proxmox hosting, pfSense hosting, TrueNAS hosting, homelab cloud, homelab datacenter"
	structuredData={{
		type: 'service',
		data: { service: serviceData }
	}}
>
	<div class="container mx-auto px-4 pt-6">
		<Breadcrumbs items={breadcrumbs} />
	</div>
	<HomelabHero />
	<HomelabFeatures />
	<CallToAction />
</Layout>
