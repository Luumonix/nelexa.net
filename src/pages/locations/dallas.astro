---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Dallas, TX Data Center | Nelexa"
  description="Nelexa Dallas: carrier-neutral data center space in the DFW Metroplex. Dedicated servers, colocation, and IP transit with redundant power, cooling, and 24/7 on-site hands."
  structuredData={{ type: 'localbusiness', data: { location: { city: 'Dallas', state: 'TX', slug: 'dallas', description: 'Nelexa Dallas data center serving the DFW Metroplex and central US.' } } }}
>
  <!-- Hero -->
  <section class="relative pt-36 pb-20 bg-black overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-primary-800/25 rounded-full blur-[140px] pointer-events-none"></div>
    <div class="absolute inset-0 grid-bg opacity-30"></div>
    <div class="container mx-auto relative z-10">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-white/10 bg-white/[0.03] text-xs font-medium text-white/70">
          <span class="w-1.5 h-1.5 rounded-full bg-primary-400"></span>
          Dallas, TX · DFW Metroplex
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter text-white mb-6">
          Dallas. <span class="gradient-text italic">Built for the central US.</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 max-w-3xl leading-relaxed">
          Our DFW facility puts you inside one of the largest and best-connected interconnection markets in the country — with low latency to the Midwest, the Southeast, and the West Coast.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="relative py-14 bg-black border-t border-white/5">
    <div class="container mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { v: "Tier III+", k: "Facility Class" },
          { v: "N+1", k: "Power & Cooling" },
          { v: "10Gbps+", k: "Dual Network" },
          { v: "24/7", k: "On-site Hands" },
        ].map(s => (
          <div class="glass-card p-6 text-center">
            <div class="text-3xl md:text-4xl font-bold text-white mb-1">{s.v}</div>
            <div class="text-xs text-white/50 uppercase tracking-wider">{s.k}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Available -->
  <section class="relative py-20 bg-black">
    <div class="container mx-auto">
      <div class="max-w-3xl mb-12">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-white mb-3">Available in Dallas</h2>
        <p class="text-white/60">Every service Nelexa offers is live and deployable in our Dallas facility.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {[
          { href: "/dedicated", title: "Dedicated Servers", desc: "HPC-18, HPC-22, HPC-24, and EVC-12 — all configurations available from Dallas." },
          { href: "/colocation", title: "Colocation", desc: "1U to full-cabinet space with transparent instant pricing and carrier-neutral cross connects." },
          { href: "/hardware", title: "Hardware Solutions", desc: "Local procurement and assembly for Dallas deployments — ship directly to our facility." },
          { href: "/ip-transit", title: "IP Transit", desc: "Carrier-diverse clean, DDoS-protected, and mixed transit on 10GE/40GE/100GE ports." },
        ].map(svc => (
          <a href={svc.href} class="group glass-card p-8 hover:border-primary-500/50 transition-colors">
            <div class="flex items-start justify-between mb-3">
              <h3 class="text-xl font-semibold text-white">{svc.title}</h3>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 group-hover:text-primary-400 group-hover:translate-x-0.5 transition-all"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
            </div>
            <p class="text-sm text-white/60 leading-relaxed">{svc.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 bg-black">
    <div class="container mx-auto">
      <div class="relative glass-card overflow-hidden p-10 md:p-14 text-center">
        <div class="absolute inset-0 bg-gradient-to-br from-primary-600/15 to-accent-700/10"></div>
        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-bold tracking-tighter text-white mb-4">Deploy in Dallas?</h2>
          <p class="text-lg text-white/70 mb-8 max-w-2xl mx-auto">Tell us what you need. We'll have it racked, cabled, and online — on your timeline.</p>
          <a href="/contact?location=dallas" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-primary-600 hover:bg-primary-500 text-white font-semibold rounded-lg transition-colors shadow-xl shadow-primary-900/40">
            Contact Sales
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
