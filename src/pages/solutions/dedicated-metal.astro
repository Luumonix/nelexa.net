---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/dedicated-metal/Hero.astro';
import Features from '../../components/dedicated-metal/Features.astro';
import Locations from '../../components/dedicated-metal/Locations.astro';
import CallToAction from '../../components/dedicated-metal/CallToAction.astro';
import Breadcrumbs from '../../components/SEO/Breadcrumbs.astro';

const serviceData = {
	type: "Hosting Service",
	name: "Dedicated Servers",
	description: "Enterprise-grade bare metal dedicated servers with full root access, customizable configurations, and 24/7 support. Perfect for high-performance applications and resource-intensive workloads."
};

const breadcrumbs = [
	{ name: 'Home', url: '/' },
	{ name: 'Solutions', url: '/solutions' },
	{ name: 'Dedicated Servers', url: '/solutions/dedicated-metal' }
];
---

<Layout 
	title="Dedicated Servers - Bare Metal Power for Your Projects | Customizable Hardware"
	description="Unleash the full potential of bare metal. From gaming servers to AI workloads, get dedicated hardware that's 100% yours. No noisy neighbors, no resource sharing - just pure performance. Custom configurations available for any use case."
	keywords="dedicated servers, bare metal servers, dedicated hosting, server rental, dedicated server hosting, bare metal hosting, dedicated metal, gaming servers, streaming servers, AI servers, machine learning servers, database servers, web servers, Phoenix dedicated servers, Miami dedicated servers, Chicago dedicated servers, London dedicated servers, cheap dedicated servers, affordable dedicated servers, enterprise dedicated servers, custom dedicated servers, managed dedicated servers, unmanaged dedicated servers"
	structuredData={{
		type: 'service',
		data: { service: serviceData }
	}}
>
	<Hero breadcrumbs={breadcrumbs} />
	<Features />
	<Locations />
	<CallToAction />
</Layout>
