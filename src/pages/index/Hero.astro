---
---

<section class="relative min-h-[95vh] flex items-center justify-center overflow-hidden bg-black pt-24">
  <!-- Gradient blobs -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-[-10%] left-[-10%] w-[600px] h-[600px] bg-primary-700/30 rounded-full blur-[120px] animate-pulse"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[600px] h-[600px] bg-accent-600/20 rounded-full blur-[120px]"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary-900/40 rounded-full blur-[140px]"></div>
  </div>

  <!-- Grid overlay -->
  <div class="absolute inset-0 grid-bg opacity-40"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/50 to-black"></div>

  <!-- Content -->
  <div class="container relative z-10 mx-auto">
    <div class="max-w-5xl mx-auto text-center">
      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-8 rounded-full border border-white/10 bg-white/[0.03] backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-primary-500"></span>
        </span>
        <span class="text-xs font-medium text-white/80">Dallas · New York — Always On</span>
      </div>

      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold font-heading text-white mb-8 tracking-tighter">
        Infrastructure
        <span class="block">that doesn't <span class="gradient-text italic">compromise.</span></span>
      </h1>

      <p class="text-lg md:text-xl text-white/70 mb-12 max-w-3xl mx-auto leading-relaxed">
        Enterprise-grade dedicated servers, colocation, IP transit, and hardware solutions — delivered from our Dallas and New York data centers. Built by engineers who understand that downtime isn't an option.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="/contact" 
          class="group inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-primary-600 hover:bg-primary-500 text-white font-semibold text-base rounded-lg transition-all duration-200 shadow-xl shadow-primary-900/40 hover:shadow-primary-700/50"
        >
          <span>Contact Sales</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        
        <a 
          href="/dedicated" 
          class="inline-flex items-center justify-center gap-2 px-7 py-3.5 text-white font-semibold text-base rounded-lg border border-white/15 bg-white/[0.03] backdrop-blur-sm hover:bg-white/[0.08] transition-colors duration-200"
        >
          <span>View Servers</span>
        </a>
      </div>

      <!-- Stats strip -->
      <div class="mt-20 pt-10 border-t border-white/10 grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto">
        <div>
          <div class="text-3xl md:text-4xl font-bold text-white mb-1">2</div>
          <div class="text-xs md:text-sm text-white/50 uppercase tracking-wider">US Data Centers</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-white mb-1">99.99%</div>
          <div class="text-xs md:text-sm text-white/50 uppercase tracking-wider">Uptime SLA</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-white mb-1">10Gbps</div>
          <div class="text-xs md:text-sm text-white/50 uppercase tracking-wider">Dual Network</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-white mb-1">24/7</div>
          <div class="text-xs md:text-sm text-white/50 uppercase tracking-wider">Remote Hands</div>
        </div>
      </div>
    </div>
  </div>
</section>
