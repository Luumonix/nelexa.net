---
const services = [
  {
    number: "01",
    title: "Dedicated Servers",
    href: "/dedicated",
    description: "Purpose-built HPC and EVC bare-metal platforms with AMD Ryzen 9000-series and dual-socket Intel Xeon configurations. Fully managed, ready in hours.",
    features: [
      "AMD Ryzen 9950X / Dual Xeon Gold 6138",
      "Up to 512GB DDR4 / 256GB DDR5",
      "Dual 10Gbps network, 1Gbps unmetered",
      "Dallas & New York availability",
    ],
  },
  {
    number: "02",
    title: "Colocation",
    href: "/colocation",
    description: "1U to full-rack space in carrier-neutral Dallas and New York facilities. Transparent instant quoting, no hidden fees, no surprises.",
    features: [
      "Half Rack: 21U, 2.5kW, 1Gbps",
      "Full Rack: 42U, 6kW, 1Gbps",
      "24/7 on-site remote hands",
      "Redundant power & cooling",
    ],
  },
  {
    number: "03",
    title: "Hardware Solutions",
    href: "/hardware",
    description: "Custom server builds, enterprise procurement, and complete lifecycle management. From single servers to complete infrastructure deployments.",
    features: [
      "Rack servers, blades, storage, networking",
      "Professional assembly & testing",
      "White-glove delivery & installation",
      "5-year warranty, 24/7 support",
    ],
  },
  {
    number: "04",
    title: "IP Transit",
    href: "/ip-transit",
    description: "Premium carrier-diverse IP transit with guaranteed performance and global reach. Clean, DDoS-protected, or mixed — on 10GE, 40GE, or 100GE ports.",
    features: [
      "Clean: $100/Gbps at 95th percentile",
      "DDoS Protected: $160/Gbps, no commit",
      "10GE / 40GE / 100GE port options",
      "Single and dual-port redundancy",
    ],
  },
];
---

<section id="services" class="relative py-24 md:py-32 bg-black overflow-hidden">
  <!-- Background accents -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-primary-900/30 rounded-full blur-[140px] pointer-events-none"></div>

  <div class="container mx-auto relative z-10">
    <div class="max-w-3xl mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-white/10 bg-white/[0.03] text-xs font-medium text-white/70">
        Our Services
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading text-white tracking-tighter mb-6">
        Four pillars. <span class="gradient-text italic">Zero compromises.</span>
      </h2>
      <p class="text-lg text-white/60 leading-relaxed">
        Every layer of your stack, delivered from a single partner. No vendor sprawl, no finger-pointing, no surprises — just infrastructure that works the way you need it to.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {services.map((service) => (
        <a 
          href={service.href}
          class="group relative glass-card p-8 md:p-10 hover:border-primary-500/50 transition-all duration-300 overflow-hidden"
        >
          <!-- Hover gradient -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary-600/0 via-primary-600/0 to-primary-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="relative z-10">
            <div class="flex items-start justify-between mb-6">
              <div class="font-mono text-sm text-primary-400 tracking-widest">{service.number}</div>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 group-hover:text-primary-400 group-hover:translate-x-1 group-hover:-translate-y-1 transition-all duration-300">
                <path d="M7 17L17 7"></path>
                <path d="M7 7h10v10"></path>
              </svg>
            </div>

            <h3 class="text-2xl md:text-3xl font-bold text-white mb-4 tracking-tight">{service.title}</h3>
            <p class="text-white/60 leading-relaxed mb-6">{service.description}</p>

            <ul class="space-y-2.5">
              {service.features.map(feature => (
                <li class="flex items-start gap-3 text-sm text-white/70">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-400 mt-0.5 flex-shrink-0">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
