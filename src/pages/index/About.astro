---
// Frontmatter section for Astro component
---

<section id="about" class="py-24 bg-white relative overflow-hidden">
  <!-- Subtle background accent -->
  <div class="absolute inset-0 opacity-[0.02]">
    <div class="absolute top-1/2 left-0 w-96 h-96 bg-blue-500 rounded-full blur-3xl transform -translate-x-1/2"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-cyan-500 rounded-full blur-3xl transform translate-x-1/2"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <!-- Main Content -->
    <div class="max-w-5xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading mb-8 text-gray-900">
          Built by engineers.
          <span class="block text-blue-500 mt-2">Run by humans.</span>
        </h2>
        
        <p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
          Look, we've all been there. 3am, site's down, and you're on hold with support for 2 hours. Or worse—getting passed between 'specialists' who are just reading from scripts. We started Charged IT Solutions because we were tired of watching good companies get screwed by hosting that costs too much and delivers too little.
        </p>
      </div>
      
      <!-- Stats Grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-20">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">99.99%</div>
          <div class="text-sm text-gray-600">Uptime SLA</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">15min</div>
          <div class="text-sm text-gray-600">Avg Response Time</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">24/7</div>
          <div class="text-sm text-gray-600">Real Support</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">50%</div>
          <div class="text-sm text-gray-600">Less Than AWS</div>
        </div>
      </div>
      
      <!-- Value Props -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Direct Support -->
        <div class="group">
          <div class="bg-gray-50 rounded-xl p-8 h-full transition-all duration-300 hover:bg-blue-50 hover:shadow-lg">
            <div class="w-14 h-14 bg-blue-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-blue-200 transition-colors">
              <svg class="w-7 h-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Direct Access</h3>
            <p class="text-gray-600 leading-relaxed">
              No tickets, no tiers. Direct access to the engineers who built your infrastructure. We answer in minutes, not days.
            </p>
          </div>
        </div>
        
        <!-- Transparent Pricing -->
        <div class="group">
          <div class="bg-gray-50 rounded-xl p-8 h-full transition-all duration-300 hover:bg-blue-50 hover:shadow-lg">
            <div class="w-14 h-14 bg-blue-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-blue-200 transition-colors">
              <svg class="w-7 h-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Clear Pricing</h3>
            <p class="text-gray-600 leading-relaxed">
              No hidden fees, no surprise bills. What you see is what you pay. Simple pricing that scales with your business.
            </p>
          </div>
        </div>
        
        <!-- Enterprise Grade -->
        <div class="group">
          <div class="bg-gray-50 rounded-xl p-8 h-full transition-all duration-300 hover:bg-blue-50 hover:shadow-lg">
            <div class="w-14 h-14 bg-blue-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-blue-200 transition-colors">
              <svg class="w-7 h-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Enterprise Ready</h3>
            <p class="text-gray-600 leading-relaxed">
              Tier III+ datacenters, redundant everything, and security that passes compliance audits. Built for business.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
