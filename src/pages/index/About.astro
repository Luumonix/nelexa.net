---
---

<section id="about" class="py-24 bg-white relative overflow-hidden">
  <!-- Subtle background accent -->
  <div class="absolute inset-0 opacity-[0.03]">
    <div class="absolute top-1/2 left-0 w-96 h-96 bg-primary-500 rounded-full blur-3xl transform -translate-x-1/2"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-accent-500 rounded-full blur-3xl transform translate-x-1/2"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <!-- Main Content -->
    <div class="max-w-5xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading mb-8 text-gray-900">
          Built by engineers.
          <span class="block text-primary-600 mt-2">Run by humans.</span>
        </h2>

        <p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
          Nelexa was started because we were tired of watching good companies get stuck with hosting that over-promises and under-delivers. One partner should handle hardware, colocation, and the network — without handoffs, without tier-1 scripts, and without the "that's not our problem" email.
        </p>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-20">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">99.99%</div>
          <div class="text-sm text-gray-600">Uptime SLA</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">2</div>
          <div class="text-sm text-gray-600">US Data Centers</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">24/7</div>
          <div class="text-sm text-gray-600">Remote Hands</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">10Gbps</div>
          <div class="text-sm text-gray-600">Dual Network</div>
        </div>
      </div>

      <!-- Value Props -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Direct Support -->
        <div class="group">
          <div class="bg-gray-50 rounded-xl p-8 h-full transition-all duration-300 hover:bg-primary-50 hover:shadow-lg">
            <div class="w-14 h-14 bg-primary-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-primary-200 transition-colors">
              <svg class="w-7 h-7 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Direct Access</h3>
            <p class="text-gray-600 leading-relaxed">
              No tickets, no tiers. Direct access to the engineers who built your infrastructure. We answer in minutes, not days.
            </p>
          </div>
        </div>

        <!-- Full Stack -->
        <div class="group">
          <div class="bg-gray-50 rounded-xl p-8 h-full transition-all duration-300 hover:bg-primary-50 hover:shadow-lg">
            <div class="w-14 h-14 bg-primary-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-primary-200 transition-colors">
              <svg class="w-7 h-7 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">One Partner, Every Layer</h3>
            <p class="text-gray-600 leading-relaxed">
              Hardware procurement, colocation, dedicated servers, and IP transit — delivered by one team with one invoice and one SLA.
            </p>
          </div>
        </div>

        <!-- Enterprise Grade -->
        <div class="group">
          <div class="bg-gray-50 rounded-xl p-8 h-full transition-all duration-300 hover:bg-primary-50 hover:shadow-lg">
            <div class="w-14 h-14 bg-primary-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-primary-200 transition-colors">
              <svg class="w-7 h-7 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Enterprise Ready</h3>
            <p class="text-gray-600 leading-relaxed">
              Tier III facilities in Dallas and New York, redundant power and cooling, and a carrier-diverse backbone engineered for mission-critical workloads.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
