---
---

<section id="contact" class="py-20 bg-white relative overflow-hidden">
  <!-- Subtle background accent -->
  <div class="absolute inset-0 opacity-[0.03]">
    <div class="absolute bottom-1/4 right-0 w-96 h-96 bg-primary-500 rounded-full blur-3xl transform translate-x-1/2"></div>
    <div class="absolute top-1/4 left-0 w-96 h-96 bg-accent-500 rounded-full blur-3xl transform -translate-x-1/2"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading mb-8 text-gray-900">
          Let's work together.
          <span class="block italic gradient-text mt-2">Three ways to start.</span>
        </h2>

        <p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
          From an instant colocation quote to a fully-scoped deployment.
          Whichever path fits, we'll meet you there.
        </p>
      </div>

      <!-- Three options -->
      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- Self-service / quote -->
        <div class="bg-white rounded-xl p-6 border border-gray-200 hover:border-primary-300 transition-colors">
          <div class="mb-4">
            <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Instant Quote</h3>
            <p class="text-sm text-gray-600 mb-4">
              Know what you need? Configure colocation space or a dedicated server and see transparent pricing now.
            </p>
            <a
              href="/colocation#quote"
              class="text-primary-600 hover:text-primary-700 text-sm font-medium inline-flex items-center gap-1"
            >
              Get a quote
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Consultation -->
        <div class="bg-white rounded-xl p-6 border border-gray-200 hover:border-primary-300 transition-colors">
          <div class="mb-4">
            <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Talk to an Engineer</h3>
            <p class="text-sm text-gray-600 mb-4">
              Not sure what you need? Send us the requirements and we'll come back with a scoped proposal. No charge.
            </p>
            <a
              href="mailto:sales@nelexa.net"
              class="text-primary-600 hover:text-primary-700 text-sm font-medium inline-flex items-center gap-1"
            >
              Email sales
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Enterprise -->
        <div class="bg-white rounded-xl p-6 border border-gray-200 hover:border-primary-300 transition-colors">
          <div class="mb-4">
            <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Enterprise</h3>
            <p class="text-sm text-gray-600 mb-4">
              Multi-rack deployments, custom SLAs, compliance, or hardware procurement at scale? Let's scope it together.
            </p>
            <a
              href="/contact"
              class="text-primary-600 hover:text-primary-700 text-sm font-medium inline-flex items-center gap-1"
            >
              Contact sales
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
