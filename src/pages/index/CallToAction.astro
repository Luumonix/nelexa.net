---

<section class="relative py-24 md:py-32 bg-black overflow-hidden">
  <div class="container mx-auto relative z-10">
    <div class="relative glass-card overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-600/20 via-primary-900/10 to-accent-700/20"></div>
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary-500/30 rounded-full blur-[100px]"></div>
      <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-accent-600/20 rounded-full blur-[100px]"></div>

      <div class="relative z-10 p-10 md:p-16 text-center">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading text-white tracking-tighter mb-6">
          Ready to <span class="gradient-text italic">build with us?</span>
        </h2>
        <p class="text-lg md:text-xl text-white/70 mb-10 max-w-2xl mx-auto leading-relaxed">
          Whether you need a single rack or an entire deployment, our team will scope, spec, and deliver infrastructure that fits your workload — not the other way around.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/contact" 
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-primary-600 hover:bg-primary-500 text-white font-semibold rounded-lg transition-colors shadow-xl shadow-primary-900/40"
          >
            Contact Sales
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
          <a 
            href="/colocation" 
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-white/5 hover:bg-white/10 text-white font-semibold rounded-lg border border-white/15 backdrop-blur-sm transition-colors"
          >
            Get Instant Quote
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
