---
import Layout from '../layouts/Layout.astro';
import SmallBusinessHero from '../components/audience/SmallBusinessHero.astro';
import SmallBusinessFeatures from '../components/audience/SmallBusinessFeatures.astro';
import SmallBusinessCTA from '../components/audience/SmallBusinessCTA.astro';
import Breadcrumbs from '../components/SEO/Breadcrumbs.astro';

const breadcrumbs = [
	{ name: 'Home', url: '/' },
	{ name: 'For Small Business', url: '/for-small-business' }
];

const serviceData = {
	type: "Small Business Hosting",
	name: "Managed Hosting Solutions for Small Business",
	description: "Enterprise-grade hosting solutions tailored for small businesses. Managed services, DDoS protection, and 24/7 support to keep your business online and secure."
};
---

<Layout 
	title="Small Business Hosting - Managed IT Solutions | Enterprise Infrastructure for SMBs"
	description="Enterprise-grade hosting for small businesses. Managed VPS, dedicated servers, DDoS protection, and 24/7 support. Focus on your business while we handle your IT infrastructure."
	keywords="small business hosting, SMB hosting, business VPS, managed hosting small business, small business cloud, business web hosting, small business IT solutions, managed services SMB, business server hosting"
	structuredData={{
		type: 'service',
		data: { service: serviceData }
	}}
>
	<div class="container mx-auto px-4 pt-6">
		<Breadcrumbs items={breadcrumbs} />
	</div>
	<SmallBusinessHero />
	<SmallBusinessFeatures />
	<SmallBusinessCTA />
</Layout>
