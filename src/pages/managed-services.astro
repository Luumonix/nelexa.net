---
import Layout from '../layouts/Layout.astro';
import ComingSoon from '../components/services/ComingSoon.astro';
import Breadcrumbs from '../components/SEO/Breadcrumbs.astro';

const breadcrumbs = [
	{ name: 'Home', url: '/' },
	{ name: 'Managed Services', url: '/managed-services' }
];
---

<Layout title="Managed IT Services - Coming Soon">
	<div class="container mx-auto px-4 pt-6">
		<Breadcrumbs items={breadcrumbs} />
	</div>
	<ComingSoon 
		serviceName="Managed IT Services"
		description="Complete IT management and support for your business. From helpdesk to infrastructure monitoring, we'll handle your technology so you can focus on growth."
		launchDate="Q1 2026"
	/>
</Layout>
