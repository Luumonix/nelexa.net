---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    id: "rack-servers",
    title: "Rack Servers",
    subtitle: "1U to 4U Configurations · Up to 2kW per Server",
    startingPrice: 2499,
    description: "Enterprise rack-mounted servers for demanding workloads with flexible configurations and premium support.",
    features: [
      "Dual/Quad Processors",
      "Up to 4TB DDR5 RAM",
      "Hot-swap Drive Bays",
      "Redundant Power Supplies",
      "Custom Configurations",
      "Professional Installation",
      "5-Year Warranty",
      "24/7 Support",
    ],
  },
  {
    id: "blade-systems",
    title: "Blade Systems",
    subtitle: "High-density chassis · 8–16 blades per enclosure",
    startingPrice: 18999,
    description: "High-density blade chassis solutions for compute-intensive environments where rack space is at a premium.",
    features: [
      "Shared Power & Cooling",
      "Unified Management",
      "Integrated Networking",
      "High-Density Compute",
      "Hot-swap Blades",
      "Professional Installation",
      "5-Year Warranty",
      "24/7 Support",
    ],
  },
  {
    id: "storage-arrays",
    title: "Storage Arrays",
    subtitle: "All-flash, hybrid, and high-capacity",
    startingPrice: 7999,
    description: "Enterprise storage solutions — from all-flash NVMe performance arrays to dense hybrid and capacity tiers.",
    features: [
      "NVMe / SAS / SATA",
      "RAID 10, 60, DP",
      "Dual Controllers",
      "Snapshot & Replication",
      "iSCSI, NFS, FC",
      "Professional Installation",
      "5-Year Warranty",
      "24/7 Support",
    ],
  },
  {
    id: "network-equipment",
    title: "Network Equipment",
    subtitle: "Switches, routers, firewalls",
    startingPrice: 1499,
    description: "Carrier-grade networking from Juniper, Arista, Cisco, and others — sized to your environment.",
    features: [
      "1/10/25/40/100GE",
      "L2/L3 Switching",
      "BGP, OSPF, MPLS",
      "Redundant PSUs",
      "Out-of-band Mgmt",
      "Professional Installation",
      "Vendor Warranties",
      "24/7 Support",
    ],
  },
  {
    id: "custom-builds",
    title: "Custom Builds",
    subtitle: "Tell us what you need — we'll build it.",
    startingPrice: null,
    description: "Purpose-built systems for GPU training, high-frequency trading, research clusters, or anything in between.",
    features: [
      "GPU / AI Accelerators",
      "Liquid & Air Cooled",
      "Custom Chassis & Racking",
      "Burn-in & Validation",
      "Documentation & Runbooks",
      "Professional Installation",
      "Lifecycle Management",
      "24/7 Support",
    ],
  },
];
---

<Layout
  title="Hardware Solutions | Nelexa"
  description="Custom server builds, enterprise procurement, and complete lifecycle management. Rack servers, blade systems, storage arrays, network equipment, and custom builds — sourced, assembled, tested, delivered, and installed."
  structuredData={{ type: 'service', data: { service: { type: 'Hardware Procurement', name: 'Nelexa Hardware Solutions', description: 'Custom server builds and enterprise procurement.' } } }}
>
  <!-- Hero -->
  <section class="relative pt-36 pb-16 bg-black overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-primary-800/25 rounded-full blur-[140px] pointer-events-none"></div>
    <div class="absolute inset-0 grid-bg opacity-30"></div>
    <div class="container mx-auto relative z-10">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-white/10 bg-white/[0.03] text-xs font-medium text-white/70">
          Hardware Solutions
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter text-white mb-6">
          From spec sheet <span class="gradient-text italic">to online.</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 max-w-3xl leading-relaxed">
          Custom server builds, enterprise procurement, and complete lifecycle management. One team sourcing, assembling, testing, and installing your infrastructure — whether it's one server or a hundred.
        </p>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="relative py-16 bg-black">
    <div class="container mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { n: "01", title: "Procurement", desc: "We source directly from OEMs and our vendor network — brand-new, validated, and ready for configuration." },
          { n: "02", title: "Assembly & Testing", desc: "Our engineers assemble, cable, burn in, and stress-test every unit against your exact spec before it ships." },
          { n: "03", title: "Delivery & Installation", desc: "White-glove shipping to your facility or ours, on-site installation, and sign-off on functional delivery." },
        ].map(step => (
          <div class="glass-card p-8">
            <div class="font-mono text-xs text-primary-400 tracking-widest mb-3">{step.n}</div>
            <h3 class="text-xl font-semibold text-white mb-3">{step.title}</h3>
            <p class="text-sm text-white/60 leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="relative py-20 bg-black border-t border-white/5">
    <div class="container mx-auto">
      <div class="max-w-3xl mb-12">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-white mb-3">Choose your hardware.</h2>
        <p class="text-white/60">Enterprise hardware solutions from single servers to complete infrastructure.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {categories.map((cat) => (
          <div id={cat.id} class="glass-card p-8 flex flex-col">
            <div class="flex items-start justify-between mb-4">
              <h3 class="text-xl font-bold text-white tracking-tight">{cat.title}</h3>
              {cat.startingPrice !== null ? (
                <div class="text-right flex-shrink-0 ml-4">
                  <div class="text-lg font-bold text-white">${cat.startingPrice.toLocaleString()}</div>
                  <div class="text-[10px] text-white/40 uppercase tracking-wider">starting</div>
                </div>
              ) : (
                <div class="text-right flex-shrink-0 ml-4">
                  <div class="text-lg font-bold text-primary-300">Custom</div>
                  <div class="text-[10px] text-white/40 uppercase tracking-wider">quote</div>
                </div>
              )}
            </div>
            <div class="text-xs text-white/50 mb-4">{cat.subtitle}</div>
            <p class="text-sm text-white/60 leading-relaxed mb-5">{cat.description}</p>

            <ul class="space-y-2 mb-6 flex-1">
              {cat.features.map(f => (
                <li class="flex items-start gap-2 text-sm text-white/70">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-400 mt-1 flex-shrink-0"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>

            <a href={`/contact?type=hardware&category=${cat.id}`} class="inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-white/5 hover:bg-primary-600 border border-white/10 hover:border-primary-500 text-white text-sm font-semibold rounded-lg transition-colors">
              Get Quote for {cat.title}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 bg-black">
    <div class="container mx-auto">
      <div class="relative glass-card overflow-hidden p-10 md:p-14 text-center">
        <div class="absolute inset-0 bg-gradient-to-br from-primary-600/15 to-accent-700/10"></div>
        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-bold tracking-tighter text-white mb-4">Have a BOM? Have an idea?</h2>
          <p class="text-lg text-white/70 mb-8 max-w-2xl mx-auto">Send it over. We'll come back with pricing, lead times, and recommendations within one business day.</p>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-primary-600 hover:bg-primary-500 text-white font-semibold rounded-lg transition-colors shadow-xl shadow-primary-900/40">
            Contact Sales
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
