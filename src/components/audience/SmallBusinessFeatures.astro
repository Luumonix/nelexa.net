---
const features = [
  {
    title: "99.9% Uptime Guarantee",
    description: "Your business stays online. Redundant power, network, and infrastructure ensure maximum availability.",
    icon: "uptime",
    specs: ["SLA-backed guarantee", "Redundant systems", "24/7 monitoring", "Proactive maintenance"]
  },
  {
    title: "Fully Managed Services",
    description: "We handle updates, security, backups, and monitoring. You focus on growing your business.",
    icon: "managed",
    specs: ["Automatic updates", "Security patches", "Daily backups", "Performance optimization"]
  },
  {
    title: "Enterprise Security",
    description: "DDoS protection, firewalls, and security monitoring included. Keep your business data safe.",
    icon: "security",
    specs: ["DDoS protection included", "Managed firewall", "Security monitoring", "SSL certificates"]
  },
  {
    title: "Predictable Pricing",
    description: "No surprise bills. Fixed monthly pricing with no hidden fees or overage charges.",
    icon: "pricing",
    specs: ["Fixed monthly rates", "No setup fees", "No overage charges", "Transparent billing"]
  },
  {
    title: "24/7 Expert Support",
    description: "Real humans answer the phone. US-based support team available whenever you need help.",
    icon: "support",
    specs: ["24/7 phone support", "US-based team", "Average 2min response", "Remote assistance"]
  },
  {
    title: "Scale As You Grow",
    description: "Start small and scale up as your business grows. Upgrade resources instantly without downtime.",
    icon: "scale",
    specs: ["Instant upgrades", "No downtime", "Flexible resources", "Growth-ready infrastructure"]
  }
];

const solutions = [
  {
    title: "E-Commerce Hosting",
    description: "High-performance hosting for online stores. Handle traffic spikes, secure payment processing, and fast page loads.",
    features: ["WooCommerce, Shopify, Magento ready", "PCI compliant infrastructure", "Automatic scaling for sales events"]
  },
  {
    title: "Business Applications",
    description: "Host your critical business applications with confidence. CRM, ERP, accounting, and custom software.",
    features: ["QuickBooks, Salesforce compatible", "Database hosting (SQL, MySQL)", "Custom application support"]
  },
  {
    title: "Email & Collaboration",
    description: "Professional email hosting and collaboration tools. Keep your team connected and productive.",
    features: ["Microsoft 365 integration", "Secure email hosting", "Team collaboration tools"]
  },
  {
    title: "Backup & Disaster Recovery",
    description: "Protect your business data with automated backups and disaster recovery solutions.",
    features: ["Automated daily backups", "Instant recovery options", "Offsite backup storage"]
  }
];
---

<section id="features" class="py-24 bg-gray-50 relative overflow-hidden">
  <!-- Subtle background accent -->
  <div class="absolute inset-0 opacity-[0.02]">
    <div class="absolute top-0 left-1/3 w-96 h-96 bg-purple-500 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/3 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-16 max-w-4xl mx-auto">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading mb-6 text-gray-900">
        Focus on your business.
        <span class="block text-purple-500 mt-2">Not your IT infrastructure.</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Enterprise-grade infrastructure with small business simplicity. 
        Everything managed, monitored, and maintained by our expert team.
      </p>
    </div>
    
    <!-- Features grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto mb-24">
      {features.map((feature) => (
        <div class="group relative bg-white rounded-xl border border-gray-200 p-8 hover:border-gray-300 hover:shadow-xl transition-all duration-300">
          <!-- Icon -->
          <div class="w-14 h-14 rounded-lg bg-gray-100 flex items-center justify-center mb-6 group-hover:bg-gray-200 transition-colors duration-300">
            {feature.icon === "uptime" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            )}
            {feature.icon === "managed" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            )}
            {feature.icon === "security" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            )}
            {feature.icon === "pricing" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {feature.icon === "support" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            )}
            {feature.icon === "scale" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            )}
          </div>
          
          <!-- Content -->
          <h3 class="text-xl font-bold text-gray-900 mb-3">{feature.title}</h3>
          <p class="text-gray-600 mb-6 leading-relaxed">{feature.description}</p>
          
          <!-- Specs list -->
          <div class="space-y-2">
            {feature.specs.map((spec) => (
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-gray-600">{spec}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Solutions Section -->
    <div class="max-w-6xl mx-auto">
      <h3 class="text-3xl font-bold text-gray-900 text-center mb-12">Solutions for Every Business Need</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {solutions.map((solution) => (
          <div class="bg-white rounded-xl border border-gray-200 p-8 hover:border-gray-300 hover:shadow-xl transition-all duration-300">
            <h4 class="text-xl font-bold text-gray-900 mb-3">{solution.title}</h4>
            <p class="text-gray-600 mb-6">{solution.description}</p>
            <ul class="space-y-2">
              {solution.features.map((feature) => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-purple-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="text-gray-600">{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
