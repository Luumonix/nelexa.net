---
import { Button } from '@/components/ui/button';
---

<section class="py-16 relative overflow-hidden">
  <!-- Background with subtle gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-950 to-black"></div>
  
  <!-- 3D Particle Network Background (matching landing page) -->
  <div class="absolute inset-0 opacity-40 z-0">
    <svg class="w-full h-full" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice">
      <defs>
        <linearGradient id="particle-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0.8" />
        </linearGradient>
      </defs>
      
      <!-- Connection lines spanning full width -->
      <!-- Top layer -->
      <line x1="0" y1="120" x2="100" y2="100" stroke="#3b82f6" stroke-width="1" opacity="0.4"/>
      <line x1="100" y1="100" x2="300" y2="150" stroke="#3b82f6" stroke-width="1" opacity="0.5"/>
      <line x1="300" y1="150" x2="500" y2="80" stroke="#06b6d4" stroke-width="1" opacity="0.4"/>
      <line x1="500" y1="80" x2="700" y2="200" stroke="#3b82f6" stroke-width="1" opacity="0.5"/>
      <line x1="700" y1="200" x2="900" y2="120" stroke="#06b6d4" stroke-width="1" opacity="0.4"/>
      <line x1="900" y1="120" x2="1100" y2="180" stroke="#3b82f6" stroke-width="1" opacity="0.5"/>
      <line x1="1100" y1="180" x2="1200" y2="160" stroke="#06b6d4" stroke-width="1" opacity="0.4"/>
      
      <!-- Middle layer -->
      <line x1="0" y1="320" x2="200" y2="300" stroke="#06b6d4" stroke-width="1" opacity="0.4"/>
      <line x1="200" y1="300" x2="400" y2="350" stroke="#06b6d4" stroke-width="1" opacity="0.4"/>
      <line x1="400" y1="350" x2="600" y2="280" stroke="#3b82f6" stroke-width="1" opacity="0.5"/>
      <line x1="600" y1="280" x2="800" y2="400" stroke="#06b6d4" stroke-width="1" opacity="0.4"/>
      <line x1="800" y1="400" x2="1000" y2="320" stroke="#3b82f6" stroke-width="1" opacity="0.5"/>
      <line x1="1000" y1="320" x2="1200" y2="380" stroke="#06b6d4" stroke-width="1" opacity="0.4"/>
      
      <!-- Bottom layer -->
      <line x1="0" y1="480" x2="150" y2="500" stroke="#3b82f6" stroke-width="1" opacity="0.4"/>
      <line x1="150" y1="500" x2="350" y2="450" stroke="#3b82f6" stroke-width="1" opacity="0.5"/>
      <line x1="350" y1="450" x2="550" y2="520" stroke="#06b6d4" stroke-width="1" opacity="0.4"/>
      <line x1="550" y1="520" x2="750" y2="480" stroke="#3b82f6" stroke-width="1" opacity="0.5"/>
      <line x1="750" y1="480" x2="950" y2="550" stroke="#06b6d4" stroke-width="1" opacity="0.4"/>
      <line x1="950" y1="550" x2="1200" y2="500" stroke="#3b82f6" stroke-width="1" opacity="0.4"/>
      
      <!-- Cross connections for 3D effect -->
      <line x1="300" y1="150" x2="200" y2="300" stroke="#3b82f6" stroke-width="0.5" opacity="0.3"/>
      <line x1="500" y1="80" x2="600" y2="280" stroke="#06b6d4" stroke-width="0.5" opacity="0.3"/>
      <line x1="700" y1="200" x2="800" y2="400" stroke="#3b82f6" stroke-width="0.5" opacity="0.3"/>
      <line x1="900" y1="120" x2="1000" y2="320" stroke="#06b6d4" stroke-width="0.5" opacity="0.3"/>
      
      <line x1="400" y1="350" x2="350" y2="450" stroke="#06b6d4" stroke-width="0.5" opacity="0.3"/>
      <line x1="600" y1="280" x2="550" y2="520" stroke="#3b82f6" stroke-width="0.5" opacity="0.3"/>
      <line x1="800" y1="400" x2="750" y2="480" stroke="#06b6d4" stroke-width="0.5" opacity="0.3"/>
      
      <!-- Additional spanning lines -->
      <line x1="0" y1="50" x2="500" y2="80" stroke="#06b6d4" stroke-width="0.8" opacity="0.3"/>
      <line x1="700" y1="200" x2="1200" y2="100" stroke="#3b82f6" stroke-width="0.8" opacity="0.3"/>
      <line x1="0" y1="250" x2="600" y2="280" stroke="#3b82f6" stroke-width="0.8" opacity="0.3"/>
      <line x1="600" y1="280" x2="1200" y2="450" stroke="#06b6d4" stroke-width="0.8" opacity="0.3"/>
      <line x1="0" y1="550" x2="750" y2="480" stroke="#06b6d4" stroke-width="0.8" opacity="0.3"/>
    </svg>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Simple Header -->
      <h2 class="text-3xl md:text-4xl font-bold font-heading mb-4 text-white">
        Ready to colocate?
      </h2>
      <p class="text-lg text-gray-300 mb-8">
        From 1U to full racks. Phoenix datacenter starting at $70/month.
      </p>
      
      <!-- Simple CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a 
          href="https://client.chargeditsolutions.com/store/colocation" 
          class="inline-flex items-center justify-center gap-3 px-8 py-3 bg-white text-gray-900 font-semibold rounded-lg transition-all duration-300 hover:bg-gray-100"
        >
          <span>Get Started</span>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        
        <a 
          href="mailto:sales@chargeditsolutions.com" 
          class="inline-flex items-center justify-center gap-3 px-8 py-3 text-white font-semibold rounded-lg border border-gray-700 transition-all duration-300 hover:bg-gray-800"
        >
          <span>Contact Us</span>
        </a>
      </div>
      
      <!-- Simple contact info -->
      <div class="flex flex-wrap items-center justify-center gap-8 text-sm text-gray-400">
        <a href="mailto:sales@chargeditsolutions.com" class="flex items-center gap-2 hover:text-white transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span>sales@chargeditsolutions.com</span>
        </a>
        
        <a href="tel:+16022096009" class="flex items-center gap-2 hover:text-white transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>(602) 209-6009</span>
        </a>
        
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>24/7 Support</span>
        </span>
      </div>
    </div>
  </div>
</section>
