---
const features = [
  {
    title: "Power Infrastructure",
    description: "2N UPS systems, N+1 generators, scalable power from 0.5A to full cabinet loads. 208V standard with 120V available.",
    icon: "power",
    specs: ["2N UPS redundancy", "N+1 diesel generators", "0.5A increments", "A+B power feeds available"]
  },
  {
    title: "Network Connectivity",
    description: "Premium blend of Lumen, Arelion, and Cogent. Optional DDoS protection up to 17+ Tbps capacity.",
    icon: "network",
    specs: ["Multi-homed BGP", "10G/40G/100G ports", "Low latency routes", "Carrier-neutral facility"]
  },
  {
    title: "Physical Security",
    description: "24/7 on-site security, biometric access control, individually locked cabinets, CCTV monitoring.",
    icon: "security",
    specs: ["Biometric access", "24/7 security staff", "Individual cabinet locks", "CCTV recording"]
  },
  {
    title: "Environmental Control",
    description: "N+1 CRAC units maintaining 68-72°F, hot/cold aisle containment, real-time monitoring.",
    icon: "cooling",
    specs: ["68-72°F maintained", "45-55% humidity", "Hot/cold aisles", "Real-time monitoring"]
  },
  {
    title: "Remote Hands",
    description: "Expert technicians available 24/7. $20/hr during maintenance windows, $50/hr emergency response.",
    icon: "support",
    specs: ["24/7 availability", "Hardware swaps", "Cable management", "Troubleshooting"]
  },
  {
    title: "Flexible Space",
    description: "From 1U to full 42U cabinets. Secure cages available for multi-rack deployments.",
    icon: "flexibility",
    specs: ["1U to 42U racks", "Private cages", "Adjacent rack guarantee", "Custom builds"]
  }
];

const pricingTiers = [
  {
    name: "1U Space",
    price: "$70",
    period: "/month",
    features: ["1U rack space @ $20/U", "1A @ 208V power ($50)", "Fair use bandwidth", "/30 IPv4 + /56 IPv6"]
  },
  {
    name: "2U Space",
    price: "$140",
    period: "/month",
    features: ["2U rack space @ $20/U", "2A @ 208V power ($100)", "Fair use bandwidth", "/30 IPv4 + /56 IPv6"]
  },
  {
    name: "3U Space",
    price: "$210",
    period: "/month",
    features: ["3U rack space @ $20/U", "3A @ 208V power ($150)", "Fair use bandwidth", "/30 IPv4 + /56 IPv6"]
  },
  {
    name: "4U Space",
    price: "$280",
    period: "/month",
    features: ["4U rack space @ $20/U", "4A @ 208V power ($200)", "Fair use bandwidth", "/30 IPv4 + /56 IPv6"]
  }
];
---

<section id="features" class="py-24 bg-gray-50 relative overflow-hidden">
  <!-- Subtle background accent -->
  <div class="absolute inset-0 opacity-[0.02]">
    <div class="absolute top-0 left-1/3 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/3 w-96 h-96 bg-cyan-500 rounded-full blur-3xl"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-16 max-w-4xl mx-auto">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading mb-6 text-gray-900">
        Enterprise infrastructure.
        <span class="block text-blue-500 mt-2">Zero compromises.</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Redundant everything. Your equipment deserves a proper home.
      </p>
    </div>
    
    <!-- Features grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {features.map((feature) => (
        <div class="group relative bg-white rounded-xl border border-gray-200 p-8 hover:border-gray-300 hover:shadow-xl transition-all duration-300">
          <!-- Icon -->
          <div class="w-14 h-14 rounded-lg bg-gray-100 flex items-center justify-center mb-6 group-hover:bg-gray-200 transition-colors duration-300">
            {feature.icon === "power" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            )}
            {feature.icon === "network" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            )}
            {feature.icon === "security" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            )}
            {feature.icon === "cooling" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
              </svg>
            )}
            {feature.icon === "support" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            )}
            {feature.icon === "flexibility" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
              </svg>
            )}
          </div>
          
          <!-- Content -->
          <h3 class="text-xl font-bold text-gray-900 mb-3">{feature.title}</h3>
          <p class="text-gray-600 mb-6 leading-relaxed">{feature.description}</p>
          
          <!-- Specs list -->
          <div class="space-y-2">
            {feature.specs.map((spec) => (
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-gray-600">{spec}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section id="pricing" class="py-24 bg-white relative overflow-hidden">
  <div class="container mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-16 max-w-4xl mx-auto">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading mb-6 text-gray-900">
        Simple pricing.
        <span class="block text-blue-500 mt-2">No surprises.</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Phoenix datacenter. Flexible power options starting at $20/U + $50/amp. 
        Scale from 1U to full racks.
      </p>
    </div>
    
    <!-- Pricing grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-7xl mx-auto">
      {pricingTiers.map((tier, index) => (
        <div class="bg-white rounded-xl border border-gray-200 p-8 hover:shadow-lg transition-all duration-300">
          <h3 class="text-xl font-bold text-gray-900 mb-2">{tier.name}</h3>
          <div class="mb-6">
            <span class="text-4xl font-bold text-gray-900">{tier.price}</span>
            <span class="text-gray-500">{tier.period}</span>
          </div>
          <ul class="space-y-3 mb-8">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-600 text-sm">{feature}</span>
              </li>
            ))}
          </ul>
          <a 
            href="https://client.chargeditsolutions.com/store/colocation"
            class="block w-full text-center px-6 py-3 font-medium rounded-lg transition-all duration-300 bg-gray-100 text-gray-900 hover:bg-gray-200"
          >
            Get Started
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
