---
import type { Region } from '@/data/regions';
import Breadcrumbs from '../SEO/Breadcrumbs.astro';

interface Props {
  region: Region;
  breadcrumbs?: Array<{ name: string; url: string; }>;
}

const { region, breadcrumbs } = Astro.props;

// Facility descriptions
const descriptions: Record<string, string> = {
  miami: 'A crucial interconnection facility serving as the gateway to Latin America. Strategic location for reaching South American markets with low latency connectivity.',
  phoenix: 'AZS-1 is one of three Iron Mountain data center facilities in the Phoenix area, offering 121,000 ft² of space and 5.8 MW of power, as well as in-house access to a wide variety of carriers and clouds.',
  chicago: 'Central US hub with nationwide connectivity. Major peering point providing low-latency access to both coasts.',
  london: 'European gateway with GDPR-compliant infrastructure. Direct connections to major European markets and transatlantic cables.'
};

const description = descriptions[region.slug] || 'Enterprise-grade datacenter facility with redundant infrastructure and 24/7 support.';

// Group certifications for better display
const certGroups = {
  federal: ['NIST 800-53', 'FISMA HIGH', 'FedRAMP', 'CMMC'],
  compliance: ['SOC 1 Type II', 'PCI-DSS', 'HIPAA', 'HITRUST'],
  iso: ['ISO 9001', 'ISO 27001', 'ISO 50001', 'ISO 14001', 'ISO 22301']
};

const phoenixCerts = region.slug === 'phoenix' ? certGroups : null;

// Icons for different sections
const icons = {
  sqft: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    <polyline points="9 22 9 12 15 12 15 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  power: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  tier: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`
};
---

<section class="relative overflow-hidden">
  <!-- Hero Section with Background -->
  <div class="relative bg-white">
    <!-- Breadcrumbs positioned at the top -->
    {breadcrumbs && (
      <div class="container mx-auto px-4 pt-6">
        <Breadcrumbs items={breadcrumbs} />
      </div>
    )}
    
    <div class="container mx-auto px-4 py-16">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <!-- Content -->
          <div class="space-y-8">
            <div>
              <h1 class="text-5xl lg:text-6xl font-bold mb-4 text-gray-900">
                {region.name}
              </h1>
              <p class="text-2xl lg:text-3xl text-gray-700 font-medium mb-6">
                {region.facility}
              </p>
              <p class="text-lg lg:text-xl text-gray-600 leading-relaxed">
                {description}
              </p>
            </div>
          </div>

          <!-- Image -->
          <div class="relative">
            <img 
              src={region.hero.image} 
              alt={`${region.facility} datacenter`}
              class="w-full h-[500px] object-cover rounded-2xl shadow-lg"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
