---
import Breadcrumbs from '../SEO/Breadcrumbs.astro';

interface Props {
  breadcrumbs?: Array<{ name: string; url: string; }>;
}

const { breadcrumbs } = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-slate-950">
  <!-- Background with subtle gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-950 to-black"></div>
  
  <!-- Network lines background -->
  <div class="absolute inset-0 opacity-30">
    <svg class="w-full h-full" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice">
      <!-- Network lines - prominent and clean -->
      <line x1="0" y1="200" x2="600" y2="400" stroke="#3b82f6" stroke-width="2" opacity="0.6"/>
      <line x1="1200" y1="200" x2="600" y2="400" stroke="#1e40af" stroke-width="2" opacity="0.6"/>
      <line x1="0" y1="600" x2="600" y2="400" stroke="#3b82f6" stroke-width="2" opacity="0.6"/>
      <line x1="1200" y1="600" x2="600" y2="400" stroke="#1e40af" stroke-width="2" opacity="0.6"/>
      
      <!-- Additional lines for network effect -->
      <line x1="0" y1="100" x2="600" y2="350" stroke="#1e40af" stroke-width="1.5" opacity="0.4"/>
      <line x1="1200" y1="100" x2="600" y2="350" stroke="#3b82f6" stroke-width="1.5" opacity="0.4"/>
      <line x1="0" y1="400" x2="600" y2="400" stroke="#3b82f6" stroke-width="1.5" opacity="0.5"/>
      <line x1="1200" y1="400" x2="600" y2="400" stroke="#1e40af" stroke-width="1.5" opacity="0.5"/>
      <line x1="0" y1="700" x2="600" y2="450" stroke="#1e40af" stroke-width="1.5" opacity="0.4"/>
      <line x1="1200" y1="700" x2="600" y2="450" stroke="#3b82f6" stroke-width="1.5" opacity="0.4"/>
      
      <!-- Center point glow -->
      <circle cx="600" cy="400" r="4" fill="#3b82f6" opacity="0.8"/>
      <circle cx="600" cy="400" r="8" fill="#3b82f6" opacity="0.4"/>
      <circle cx="600" cy="400" r="12" fill="#3b82f6" opacity="0.2"/>
    </svg>
  </div>

  <!-- Breadcrumbs positioned absolutely at the top -->
  {breadcrumbs && (
    <div class="absolute top-6 left-0 right-0 z-20">
      <div class="container mx-auto px-6 md:px-12 lg:px-16 xl:px-24">
        <Breadcrumbs items={breadcrumbs} />
      </div>
    </div>
  )}

  <div class="container relative z-10 px-6 md:px-12 lg:px-16 xl:px-24 mx-auto">
    <div class="max-w-5xl mx-auto text-center">
      <!-- Main heading -->
      <h1 class="text-5xl md:text-5xl lg:text-7xl xl:text-7.5xl font-bold font-heading text-white mb-8">
        17 Tbps of pure defense.
        <span class="block text-blue-400 mt-2">
          Attacks stop here.
        </span>
      </h1>
      
      <!-- Subtitle -->
      <p class="text-xl md:text-2xl text-gray-300 mb-12 max-w-3xl mx-auto">
        Global anycast network. Instant mitigation. Zero downtime. 
        Your infrastructure stays online while attackers burn resources.
      </p>
      
      <!-- Stats -->
      <div class="grid grid-cols-3 gap-8 max-w-2xl mx-auto mb-12">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-white mb-1">17+</div>
          <div class="text-sm text-gray-400">Tbps Capacity</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-white mb-1">&lt;10s</div>
          <div class="text-sm text-gray-400">Mitigation Time</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-white mb-1">24/7</div>
          <div class="text-sm text-gray-400">SOC Monitoring</div>
        </div>
      </div>
      
      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="https://client.chargeditsolutions.com/store/ddos-protection" 
          class="group inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-gray-900 font-semibold text-lg rounded-lg transition-all duration-300 hover:bg-gray-100 transform hover:scale-[1.02]"
        >
          <span>Get Protected</span>
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        
        <a 
          href="#network" 
          class="group inline-flex items-center justify-center gap-3 px-8 py-4 text-white font-semibold text-lg rounded-lg border-2 border-white/20 transition-all duration-300 hover:bg-white/10 hover:border-white/40"
        >
          <span>View Network</span>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
