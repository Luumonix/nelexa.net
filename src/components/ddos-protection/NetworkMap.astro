---
// Define location data with real coordinates for the map
const locations = [
  { name: "Los Angeles, CA", region: "North America", lat: 34.0522, lng: -118.2437, capacity: "2 Tbps" },
  { name: "San Jose, CA", region: "North America", lat: 37.3382, lng: -121.8863, capacity: "1.5 Tbps" },
  { name: "Phoenix, AZ", region: "North America", lat: 33.4484, lng: -112.0740, capacity: "1 Tbps" },
  { name: "Salt Lake City, UT", region: "North America", lat: 40.7608, lng: -111.8910, capacity: "1 Tbps" },
  { name: "Dallas, TX", region: "North America", lat: 32.7767, lng: -96.7970, capacity: "1.5 Tbps" },
  { name: "Chicago, IL", region: "North America", lat: 41.8781, lng: -87.6298, capacity: "2 Tbps" },
  { name: "Miami, FL", region: "North America", lat: 25.7617, lng: -80.1918, capacity: "1 Tbps" },
  { name: "New York, NY", region: "North America", lat: 40.7128, lng: -74.0060, capacity: "2 Tbps" },
  { name: "London, GB", region: "Europe", lat: 51.5074, lng: -0.1278, capacity: "1.5 Tbps" },
  { name: "Frankfurt, DE", region: "Europe", lat: 50.1109, lng: 8.6821, capacity: "2 Tbps" },
  { name: "Amsterdam, NL", region: "Europe", lat: 52.3676, lng: 4.9041, capacity: "1.5 Tbps" },
  { name: "Madrid, ES", region: "Europe", lat: 40.4168, lng: -3.7038, capacity: "1 Tbps" },
  { name: "Sofia, BG", region: "Europe", lat: 42.6977, lng: 23.3219, capacity: "500 Gbps" },
  { name: "Warsaw, PL", region: "Europe", lat: 52.2297, lng: 21.0122, capacity: "500 Gbps" },
  { name: "Singapore, SG", region: "Asia", lat: 1.3521, lng: 103.8198, capacity: "1.5 Tbps" },
  { name: "Tokyo, JP", region: "Asia", lat: 35.6762, lng: 139.6503, capacity: "2 Tbps" },
  { name: "Sydney, AU", region: "Oceania", lat: -33.8688, lng: 151.2093, capacity: "1 Tbps" }
];

// Group locations by region
const regions: Record<string, typeof locations> = {};
locations.forEach(location => {
  if (!regions[location.region]) {
    regions[location.region] = [];
  }
  regions[location.region].push(location);
});

// Calculate total capacity
const totalCapacity = locations.reduce((sum, loc) => {
  const capacity = parseFloat(loc.capacity);
  const unit = loc.capacity.includes('Tbps') ? 1000 : 1;
  return sum + (capacity * unit);
}, 0) / 1000;
---

<section id="network" class="py-24 bg-white relative overflow-hidden">
  <div class="container mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16 max-w-4xl mx-auto">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading mb-6 text-gray-900">
        17 scrubbing centers.
        <span class="block text-blue-500 mt-2">Zero blind spots.</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Strategically positioned to stop attacks close to their source. 
        Your traffic takes the shortest path to clean infrastructure.
      </p>
    </div>
    
    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto mb-16">
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">17</div>
        <div class="text-sm text-gray-600">Global Locations</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">{totalCapacity.toFixed(1)}</div>
        <div class="text-sm text-gray-600">Tbps Total Capacity</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">4</div>
        <div class="text-sm text-gray-600">Continents</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">100%</div>
        <div class="text-sm text-gray-600">Global Coverage</div>
      </div>
    </div>
    
    <!-- Map container -->
    <div class="max-w-7xl mx-auto relative z-0">
      <div class="bg-gray-900 rounded-2xl overflow-hidden shadow-2xl">
        <div id="network-map-container" class="w-full h-[600px] relative">
          <!-- Loading state -->
          <div id="map-loading" class="absolute inset-0 flex items-center justify-center bg-gray-900 z-10">
            <div class="text-gray-500">
              <svg class="w-8 h-8 animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Location details -->
    <div class="mt-16 max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {Object.entries(regions).map(([region, locs], index) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200">
            <details class="group">
              <summary class="cursor-pointer list-none">
                <div class="px-6 py-3 flex items-center justify-between">
                  <h3 class="text-lg font-bold text-gray-900 my-0">
                    {region}
                  </h3>
                  <svg class="w-5 h-5 text-gray-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </summary>
              <div class="px-6 pb-6 pt-0">
                <ul class="space-y-3">
                  {locs.map((location) => (
                    <li class="flex items-start gap-2">
                      <span class="w-1 h-1 bg-gray-400 rounded-full mt-2 flex-shrink-0"></span>
                      <div class="flex-1">
                        <p class="text-sm font-medium text-gray-900">{location.name}</p>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script is:inline>
  // Lazy load Leaflet when the map comes into view
  const loadLeaflet = () => {
    return new Promise((resolve) => {
      // Check if already loaded
      if (window.L) {
        resolve();
        return;
      }

      // Load CSS
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
      link.integrity = 'sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=';
      link.crossOrigin = '';
      document.head.appendChild(link);

      // Load JS
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      script.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
      script.crossOrigin = '';
      script.onload = resolve;
      document.head.appendChild(script);
    });
  };

  // Location data
  const locations = [
    { name: "Los Angeles, CA", region: "North America", lat: 34.0522, lng: -118.2437, capacity: "2 Tbps" },
    { name: "San Jose, CA", region: "North America", lat: 37.3382, lng: -121.8863, capacity: "1.5 Tbps" },
    { name: "Phoenix, AZ", region: "North America", lat: 33.4484, lng: -112.0740, capacity: "1 Tbps" },
    { name: "Salt Lake City, UT", region: "North America", lat: 40.7608, lng: -111.8910, capacity: "1 Tbps" },
    { name: "Dallas, TX", region: "North America", lat: 32.7767, lng: -96.7970, capacity: "1.5 Tbps" },
    { name: "Chicago, IL", region: "North America", lat: 41.8781, lng: -87.6298, capacity: "2 Tbps" },
    { name: "Miami, FL", region: "North America", lat: 25.7617, lng: -80.1918, capacity: "1 Tbps" },
    { name: "New York, NY", region: "North America", lat: 40.7128, lng: -74.0060, capacity: "2 Tbps" },
    { name: "London, GB", region: "Europe", lat: 51.5074, lng: -0.1278, capacity: "1.5 Tbps" },
    { name: "Frankfurt, DE", region: "Europe", lat: 50.1109, lng: 8.6821, capacity: "2 Tbps" },
    { name: "Amsterdam, NL", region: "Europe", lat: 52.3676, lng: 4.9041, capacity: "1.5 Tbps" },
    { name: "Madrid, ES", region: "Europe", lat: 40.4168, lng: -3.7038, capacity: "1 Tbps" },
    { name: "Sofia, BG", region: "Europe", lat: 42.6977, lng: 23.3219, capacity: "500 Gbps" },
    { name: "Warsaw, PL", region: "Europe", lat: 52.2297, lng: 21.0122, capacity: "500 Gbps" },
    { name: "Singapore, SG", region: "Asia", lat: 1.3521, lng: 103.8198, capacity: "1.5 Tbps" },
    { name: "Tokyo, JP", region: "Asia", lat: 35.6762, lng: 139.6503, capacity: "2 Tbps" },
    { name: "Sydney, AU", region: "Oceania", lat: -33.8688, lng: 151.2093, capacity: "1 Tbps" }
  ];

  // Initialize map when it comes into view
  document.addEventListener('DOMContentLoaded', () => {
    const mapContainer = document.getElementById('network-map-container');
    if (!mapContainer) return;

    // Create intersection observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          observer.unobserve(entry.target);
          
          // Load Leaflet and initialize map
          loadLeaflet().then(() => {
            initializeMap();
          });
        }
      });
    }, {
      rootMargin: '100px' // Start loading 100px before the map comes into view
    });

    observer.observe(mapContainer);
  });

  const initializeMap = () => {
      const mapContainer = document.getElementById('network-map-container');
      if (!mapContainer) return;

      // Hide loading state
      const loadingEl = document.getElementById('map-loading');
      if (loadingEl) {
        loadingEl.style.display = 'none';
      }

      // Create map with dark theme
      const map = window.L.map('network-map-container', {
        center: [20, 0],
        zoom: 2,
        minZoom: 2,
        maxZoom: 6,
        worldCopyJump: true,
        zoomControl: false
      });

      // Add zoom control to top right
      window.L.control.zoom({
        position: 'topright'
      }).addTo(map);

      // Add dark tile layer
      window.L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 19
      }).addTo(map);

      // Create custom icon with HTML
      const createMarkerHtml = (name, capacity) => {
        return `
          <div style="
            width: 8px;
            height: 8px;
            background: #60a5fa;
            border-radius: 50%;
            position: relative;
          "></div>
        `;
      };

      // Add markers for each location
      locations.forEach((location) => {
        const popIcon = window.L.divIcon({
          className: 'custom-marker',
          html: createMarkerHtml(location.name, location.capacity),
          iconSize: [12, 12],
          iconAnchor: [6, 6],
          popupAnchor: [0, -8]
        });

        const marker = window.L.marker([location.lat, location.lng], { icon: popIcon })
          .addTo(map)
          .bindPopup(`
            <div style="font-size: 14px;">
              <strong style="color: #ffffff;">${location.name}</strong><br>
              <span style="color: #e5e7eb; font-size: 12px;">${location.region}</span><br>
              <span style="color: #9ca3af; font-size: 12px;">Capacity: ${location.capacity}</span>
            </div>
          `);
      });

      // Handle window resize
      window.addEventListener('resize', () => {
        map.invalidateSize();
      });
  };
</script>

<style>
  /* Reset summary default styles */
  summary::-webkit-details-marker {
    display: none;
  }
  
  /* Fix alignment issues */
  summary {
    display: block !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  
  summary > div {
    margin: 0 !important;
  }
  
  /* Leaflet container styles */
  #network-map-container {
    background-color: #111827;
  }
  
  /* Custom marker styles */
  :global(.custom-marker) {
    background: transparent !important;
    border: none !important;
  }
  
  /* Ensure markers are visible */
  :global(.leaflet-marker-icon) {
    z-index: 600 !important;
  }
  
  :global(.leaflet-marker-shadow) {
    display: none !important;
  }
  
  /* Popup styles */
  :global(.leaflet-popup-content-wrapper) {
    background: rgba(31, 41, 55, 0.95);
    color: white;
    border-radius: 8px;
    padding: 0;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(59, 130, 246, 0.3);
  }
  
  :global(.leaflet-popup-content) {
    margin: 12px;
    line-height: 1.5;
  }
  
  :global(.leaflet-popup-tip) {
    background: rgba(31, 41, 55, 0.95);
    border-bottom: 1px solid rgba(59, 130, 246, 0.3);
  }
  
  /* Override Leaflet controls for dark theme */
  :global(.leaflet-control-zoom a) {
    background-color: rgba(31, 41, 55, 0.9);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  :global(.leaflet-control-zoom a:hover) {
    background-color: rgba(31, 41, 55, 1);
  }
  
  /* Simple hover effect for markers */
  :global(.custom-marker) {
    transition: transform 0.2s ease;
  }
  
  :global(.custom-marker:hover) {
    transform: scale(1.2);
  }
</style>
