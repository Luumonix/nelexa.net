---
const features = [
  {
    title: "17+ Tbps Capacity",
    description: "Handle volumetric attacks that would flatten most networks. Our global infrastructure absorbs the biggest attacks without breaking a sweat.",
    icon: "capacity",
    specs: ["UDP Floods", "SYN Floods", "ICMP Floods", "DNS Amplification"]
  },
  {
    title: "Global Anycast Network",
    description: "17 scrubbing centers worldwide. Traffic gets cleaned at the closest location. Your users never notice.",
    icon: "network",
    specs: ["Los Angeles", "New York", "London", "Frankfurt", "Tokyo", "Sydney"]
  },
  {
    title: "Layer 3-7 Protection",
    description: "Not just volumetric. We stop application-layer attacks, SSL floods, and everything in between.",
    icon: "layers",
    specs: ["HTTP/HTTPS Floods", "Slowloris", "SSL Exhaustion", "DNS Attacks"]
  },
  {
    title: "Always-On Detection",
    description: "No waiting for you to notice. Attacks detected in under 1ms, mitigated in under 10 seconds.",
    icon: "detection",
    specs: ["24/7 Monitoring", "Auto-Mitigation", "Real-time Alerts", "Attack Analytics"]
  },
  {
    title: "Stateful Inspection",
    description: "Smart filtering that knows the difference between your customers and attackers. No false positives.",
    icon: "shield",
    specs: ["TCP State Tracking", "Pattern Recognition", "Behavioral Analysis", "Rate Limiting"]
  },
  {
    title: "Simple Integration",
    description: "GRE tunnels for IPv4, IPIP6 for IPv6. If you can configure a tunnel, you can deploy our protection.",
    icon: "integration",
    specs: ["BGP Support", "GRE Tunnels", "IPIP6 Tunnels", "API Access"]
  }
];
---

<section id="features" class="py-24 bg-gray-50 relative overflow-hidden">
  <!-- Subtle background accent -->
  <div class="absolute inset-0 opacity-[0.02]">
    <div class="absolute top-0 right-1/3 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-1/3 w-96 h-96 bg-cyan-500 rounded-full blur-3xl"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-16 max-w-4xl mx-auto">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading mb-6 text-gray-900">
        Built to stop attacks.
        <span class="block text-blue-500 mt-2">Not your business.</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Every attack vector covered. Every edge case handled. 
        Your infrastructure stays online while attackers waste their resources.
      </p>
    </div>
    
    <!-- Features grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {features.map((feature) => (
        <div class="group relative bg-white rounded-xl border border-gray-200 p-8 hover:border-gray-300 hover:shadow-xl transition-all duration-300">
          <!-- Icon -->
          <div class="w-14 h-14 rounded-lg bg-gray-100 flex items-center justify-center mb-6 group-hover:bg-gray-200 transition-colors duration-300">
            {feature.icon === "capacity" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            )}
            {feature.icon === "network" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            )}
            {feature.icon === "layers" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            )}
            {feature.icon === "detection" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {feature.icon === "shield" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            )}
            {feature.icon === "integration" && (
              <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            )}
          </div>
          
          <!-- Content -->
          <h3 class="text-xl font-bold text-gray-900 mb-3">{feature.title}</h3>
          <p class="text-gray-600 mb-6 leading-relaxed">{feature.description}</p>
          
          <!-- Specs list -->
          <div class="space-y-2">
            {feature.specs.map((spec) => (
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-gray-600">{spec}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
