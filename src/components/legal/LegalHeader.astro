---
interface Props {
  title: string;
  lastUpdated?: Date;
}

const { title, lastUpdated } = Astro.props;
const formattedDate = lastUpdated
  ? lastUpdated.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<div class="relative pt-32 pb-10 bg-black border-b border-white/10 overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[300px] bg-primary-800/20 rounded-full blur-[140px] pointer-events-none"></div>
  <div class="container mx-auto relative z-10">
    <div class="flex items-center mb-4 text-sm text-white/50">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/legal" class="hover:text-white transition-colors">Legal</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">{title}</span>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold tracking-tighter mb-2 text-white">{title}</h1>
    {formattedDate && <p class="text-sm text-white/50 m-0">Last updated: {formattedDate}</p>}
  </div>
</div>
