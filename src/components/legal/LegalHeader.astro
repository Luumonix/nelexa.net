---
interface Props {
  title: string;
  lastUpdated?: Date;
}

const { title, lastUpdated } = Astro.props;
const formattedDate = lastUpdated ? lastUpdated.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}) : null;
---

<div class="pt-32 pb-4 bg-white border-b border-gray-200">
  <div class="container">
    <div class="flex items-center mb-4 text-sm text-gray-500">
      <a href="/" class="text-gray-500 no-underline hover:text-primary-900 transition-colors duration-200">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-500">{title}</span>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold mb-2 text-primary-900">{title}</h1>
    {formattedDate && (
      <p class="text-sm text-gray-500 m-0">Last updated: {formattedDate}</p>
    )}
  </div>
</div>

<style>
  @media (max-width: 768px) {
    .pt-32 {
      padding-top: 7rem; /* Adjusted for mobile navbar height */
    }
  }
</style>
