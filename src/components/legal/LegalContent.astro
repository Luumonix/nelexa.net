---
// No props needed, using slots instead
---

<div class="legal-prose pb-16 md:pb-24 pt-8 text-white/75">
  <div class="w-full">
    <slot />
  </div>
</div>

<style>
  :global(.legal-prose h2:first-child) {
    margin-top: 0;
  }
  :global(.legal-prose h2) {
    @apply text-2xl md:text-3xl font-bold mt-12 mb-4 pb-2 border-b border-white/10 text-white;
    scroll-margin-top: 100px;
  }
  :global(.legal-prose h3) {
    @apply text-xl md:text-2xl font-bold mt-8 mb-3 text-white;
    scroll-margin-top: 100px;
  }
  :global(.legal-prose h4) {
    @apply text-lg md:text-xl font-bold mt-6 mb-2 text-white;
    scroll-margin-top: 100px;
  }
  :global(.legal-prose p) {
    @apply mb-4 leading-relaxed text-white/70;
  }
  :global(.legal-prose ul),
  :global(.legal-prose ol) {
    @apply mb-6 pl-6 text-white/70;
  }
  :global(.legal-prose li) {
    @apply mb-2;
  }
  :global(.legal-prose a) {
    @apply text-primary-400 no-underline border-b border-transparent transition-colors duration-200 hover:border-primary-400;
  }
  :global(.legal-prose strong) {
    @apply text-white;
  }
  :global(.legal-prose blockquote) {
    @apply border-l-4 border-white/20 pl-4 ml-0 mr-0 italic text-white/60;
  }
  :global(.legal-prose table) {
    @apply w-full border-collapse mb-6;
  }
  :global(.legal-prose th),
  :global(.legal-prose td) {
    @apply p-3 border border-white/10 text-left text-white/70;
  }
  :global(.legal-prose th) {
    @apply bg-white/[0.03] font-semibold text-white;
  }
  :global(.legal-prose tr:nth-child(even)) {
    @apply bg-white/[0.02];
  }
  :global(.legal-prose code) {
    @apply bg-white/[0.05] px-1 py-0.5 rounded text-sm font-mono text-primary-300;
  }
  :global(.legal-prose pre) {
    @apply bg-white/[0.03] p-4 rounded-md overflow-x-auto mb-6 border border-white/10;
  }
  :global(.legal-prose pre code) {
    @apply bg-transparent p-0 rounded-none;
  }
  :global(.legal-prose hr) {
    @apply border-0 h-px bg-white/10 my-8;
  }
</style>
