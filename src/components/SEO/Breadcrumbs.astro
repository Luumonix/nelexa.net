---
interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const breadcrumbsWithAbsoluteUrls = items.map(item => ({
  ...item,
  url: item.url.startsWith('http') ? item.url : `https://nelexa.net${item.url}`
}));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbsWithAbsoluteUrls.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": {
      "@type": "Thing",
      "@id": item.url
    }
  }))
};
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex items-center space-x-2 text-sm text-white/60">
    {items.map((item, index) => (
      <>
        <li>
          {index === items.length - 1 ? (
            <span class="text-white font-medium" aria-current="page">{item.name}</span>
          ) : (
            <a href={item.url} class="hover:text-primary-400 transition-colors">
              {item.name}
            </a>
          )}
        </li>
        {index < items.length - 1 && (
          <li aria-hidden="true">
            <svg class="w-4 h-4 text-white/30" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          </li>
        )}
      </>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
