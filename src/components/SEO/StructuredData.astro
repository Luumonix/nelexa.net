---
interface Props {
  type?: 'organization' | 'service' | 'localbusiness' | 'breadcrumb';
  data?: any;
}

const { type = 'organization', data } = Astro.props;

// Organization Schema (default)
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Charged IT Solutions LLC",
  "alternateName": "Charged IT Solutions",
  "url": "https://chargeditsolutions.com",
  "logo": "https://chargeditsolutions.com/android-chrome-512x512.png",
  "description": "Enterprise-grade cloud infrastructure, colocation, DDoS protection, and managed services provider with datacenters in Phoenix, Miami, Chicago, and London.",
  "foundingDate": "2023",
  "founders": [
    {
      "@type": "Person",
      "name": "Zachary Dumas"
    },
    {
      "@type": "Person",
      "name": "Ishmeet Thethi"
    }
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "14853 N 100th Pl",
    "addressLocality": "Scottsdale",
    "addressRegion": "AZ",
    "postalCode": "85260",
    "addressCountry": "US"
  },
  "sameAs": [
    "https://x.com/cits_llc",
    "https://www.linkedin.com/company/charged-it-solutions-llc",
    "https://github.com/chargeditsolutionsllc",
    "https://discord.chargeditsolutions.com"
  ],
  "contactPoint": [{
    "@type": "ContactPoint",
    "contactType": "customer support",
    "telephone": "+1-480-863-1188",
    "email": "support@chargeditsolutions.com",
    "availableLanguage": ["en"],
    "areaServed": ["US", "GB", "Worldwide"],
    "contactOption": ["TollFree", "HearingImpairedSupported"]
  }],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Infrastructure Services",
    "itemListElement": [
      {
        "@type": "Service",
        "name": "Virtual Private Servers (VPS)",
        "description": "High-performance cloud VPS hosting and virtual machines starting at $5/month"
      },
      {
        "@type": "Service",
        "name": "Dedicated Servers",
        "description": "Bare metal dedicated servers with full root access"
      },
      {
        "@type": "Service",
        "name": "Colocation Services",
        "description": "Datacenter colocation starting at $70/month"
      },
      {
        "@type": "Service",
        "name": "DDoS Protection",
        "description": "Enterprise-grade DDoS protection and mitigation"
      }
    ]
  }
};

// Service Schema
const serviceSchema = data?.service ? {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": data.service.type,
  "provider": {
    "@type": "Organization",
    "name": "Charged IT Solutions LLC"
  },
  "name": data.service.name,
  "description": data.service.description,
  "areaServed": data.service.areaServed || ["US", "GB", "Worldwide"],
  "hasOfferCatalog": data.service.offers ? {
    "@type": "OfferCatalog",
    "name": data.service.name + " Plans",
    "itemListElement": data.service.offers
  } : undefined
} : null;

// Local Business Schema for datacenter locations
const localBusinessSchema = data?.location ? {
  "@context": "https://schema.org",
  "@type": "DataCenter",
  "name": `Charged IT Solutions - ${data.location.city} Datacenter`,
  "parentOrganization": {
    "@type": "Organization",
    "name": "Charged IT Solutions LLC"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": data.location.city,
    "addressRegion": data.location.state,
    "addressCountry": data.location.country,
    "postalCode": data.location.postalCode
  },
  "geo": data.location.coordinates ? {
    "@type": "GeoCoordinates",
    "latitude": data.location.coordinates.lat,
    "longitude": data.location.coordinates.lng
  } : undefined,
  "description": data.location.description,
  "telephone": "+1-800-CHARGED",
  "url": `https://chargeditsolutions.com/regions/${data.location.slug}`,
  "image": data.location.image,
  "priceRange": "$$"
} : null;


// Breadcrumb Schema
const breadcrumbSchema = data?.breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": data.breadcrumbs.map((item: any, index: number) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": item.url
  }))
} : null;

// Select the appropriate schema based on type
let selectedSchema;
switch (type) {
  case 'service':
    selectedSchema = serviceSchema;
    break;
  case 'localbusiness':
    selectedSchema = localBusinessSchema;
    break;
  case 'breadcrumb':
    selectedSchema = breadcrumbSchema;
    break;
  default:
    selectedSchema = organizationSchema;
}
---

{selectedSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(selectedSchema)} />
)}
