---
interface Props {
  type?: 'organization' | 'service' | 'localbusiness' | 'breadcrumb';
  data?: any;
}

const { type = 'organization', data } = Astro.props;

// Organization Schema (default)
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Elcro Digital Services, LLC dba Nelexa Networks",
  "alternateName": "Nelexa",
  "url": "https://nelexa.net",
  "logo": "https://nelexa.net/android-chrome-512x512.png",
  "description": "Enterprise-grade dedicated servers, colocation, IP transit, and hardware solutions with data centers in Dallas and New York.",
  "sameAs": [
    "https://discord.gg/nelexa"
  ],
  "contactPoint": [{
    "@type": "ContactPoint",
    "contactType": "sales",
    "email": "sales@nelexa.net",
    "availableLanguage": ["en"],
    "areaServed": ["US", "Worldwide"]
  }],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Infrastructure Services",
    "itemListElement": [
      {
        "@type": "Service",
        "name": "Dedicated Servers",
        "description": "High-performance bare-metal dedicated servers with AMD Ryzen and Intel Xeon configurations."
      },
      {
        "@type": "Service",
        "name": "Colocation",
        "description": "1U to full-rack colocation in Dallas and New York with transparent instant quoting."
      },
      {
        "@type": "Service",
        "name": "Hardware Solutions",
        "description": "Custom server builds, enterprise procurement, and complete lifecycle management."
      },
      {
        "@type": "Service",
        "name": "IP Transit",
        "description": "Clean, DDoS-protected, and mixed IP transit with carrier-diverse global reach."
      }
    ]
  }
};

const serviceSchema = data?.service ? {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": data.service.type,
  "provider": {
    "@type": "Organization",
    "name": "Elcro Digital Services, LLC dba Nelexa Networks"
  },
  "name": data.service.name,
  "description": data.service.description,
  "areaServed": data.service.areaServed || ["US", "Worldwide"]
} : null;

const localBusinessSchema = data?.location ? {
  "@context": "https://schema.org",
  "@type": "DataCenter",
  "name": `Nelexa — ${data.location.city} Data Center`,
  "parentOrganization": {
    "@type": "Organization",
    "name": "Elcro Digital Services, LLC dba Nelexa Networks"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": data.location.city,
    "addressRegion": data.location.state,
    "addressCountry": data.location.country || "US"
  },
  "description": data.location.description,
  "url": `https://nelexa.net/locations/${data.location.slug}`
} : null;

const breadcrumbSchema = data?.breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": data.breadcrumbs.map((item: any, index: number) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": item.url
  }))
} : null;

let selectedSchema;
switch (type) {
  case 'service':
    selectedSchema = serviceSchema;
    break;
  case 'localbusiness':
    selectedSchema = localBusinessSchema;
    break;
  case 'breadcrumb':
    selectedSchema = breadcrumbSchema;
    break;
  default:
    selectedSchema = organizationSchema;
}
---

{selectedSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(selectedSchema)} />
)}
