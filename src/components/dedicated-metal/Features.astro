---

<section id="configurations" class="py-24 bg-gray-50 relative overflow-hidden">
  <!-- Subtle background accent -->
  <div class="absolute inset-0 opacity-[0.02]">
    <div class="absolute top-0 right-1/3 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-1/3 w-96 h-96 bg-cyan-500 rounded-full blur-3xl"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-16 max-w-4xl mx-auto">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading mb-6 text-gray-900">
        Real servers. Real inventory.
        <span class="block text-blue-500 mt-2">Pick yours.</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        HPE ProLiant servers in our Phoenix datacenter. 
        What you see is what's available right now.
      </p>
    </div>
    
    <!-- Server inventory table -->
    <div class="max-w-7xl mx-auto">
      <div class="overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
        <table class="w-full">
          <thead>
            <tr class="bg-gray-100 border-b border-gray-200">
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Server</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Processor</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Memory</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Storage</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Monthly</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            {availableServers.map((server) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-medium text-gray-900">Node {server.node}</span>
                    <span class={`px-2 py-0.5 text-xs rounded-full ${
                      server.generation === 'G9' 
                        ? 'bg-blue-100 text-blue-700' 
                        : 'bg-gray-200 text-gray-600'
                    }`}>
                      {server.generation}
                    </span>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <div>
                    <div class="text-sm font-medium text-gray-900">{server.cpu}</div>
                    <div class="text-xs text-gray-500">{server.cores}</div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="text-sm text-gray-900">{server.ram}</span>
                </td>
                <td class="px-6 py-4">
                  <span class="text-sm text-gray-900">{server.storage}</span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div>
                    <span class="text-2xl font-bold text-gray-900">{server.price}</span>
                    <span class="text-sm text-gray-500">/mo</span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right">
                  <a 
                    href={`https://client.chargeditsolutions.com/store/phx-az-metal?node=${server.node}`}
                    class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-blue-500 to-blue-600 text-white text-sm font-medium rounded-lg hover:shadow-lg hover:shadow-blue-500/25 transition-all duration-300"
                  >
                    Reserve →
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile view -->
      <div class="lg:hidden mt-8 space-y-4">
        {availableServers.map((server) => (
          <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg transition-shadow">
            <div class="flex justify-between items-start mb-4">
              <div>
                <span class="font-semibold text-gray-900">Node {server.node}</span>
                <span class={`ml-2 px-2 py-0.5 text-xs rounded-full ${
                  server.generation === 'G9' 
                    ? 'bg-blue-100 text-blue-700' 
                    : 'bg-gray-200 text-gray-600'
                }`}>
                  {server.generation}
                </span>
              </div>
              <div class="text-right">
                <span class="text-2xl font-bold text-gray-900">{server.price}</span>
                <span class="text-sm text-gray-500">/mo</span>
              </div>
            </div>
            <div class="space-y-2 text-sm mb-4">
              <div class="flex justify-between">
                <span class="text-gray-500">CPU:</span>
                <span class="text-gray-900 text-right">{server.cpu}<br/><span class="text-xs">{server.cores}</span></span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">RAM:</span>
                <span class="text-gray-900">{server.ram}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Storage:</span>
                <span class="text-gray-900 text-right">{server.storage}</span>
              </div>
            </div>
            <a 
              href={`https://client.chargeditsolutions.com/store/phx-az-metal?node=${server.node}`}
              class="w-full inline-flex justify-center items-center px-4 py-2 bg-gradient-to-r from-blue-500 to-blue-600 text-white text-sm font-medium rounded-lg hover:shadow-lg hover:shadow-blue-500/25 transition-all duration-300"
            >
              Reserve This Server →
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- Additional info -->
    <div class="mt-16 max-w-7xl mx-auto">
      <h3 class="text-2xl font-bold text-gray-900 text-center mb-8">Every server includes:</h3>
      <div class="grid md:grid-cols-4 gap-6">
        <!-- Bandwidth -->
        <div class="bg-white rounded-xl p-6 border border-gray-200 hover:border-gray-300 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">30TB Bandwidth</h4>
          <p class="text-sm text-gray-600">Monthly transfer included. 95th percentile billing.</p>
        </div>
        
        <!-- IP Addresses -->
        <div class="bg-white rounded-xl p-6 border border-gray-200 hover:border-gray-300 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">IP Allocation</h4>
          <p class="text-sm text-gray-600">1 IPv4 address included. /56 IPv6 subnet available.</p>
        </div>
        
        <!-- Management -->
        <div class="bg-white rounded-xl p-6 border border-gray-200 hover:border-gray-300 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">iLO Advanced</h4>
          <p class="text-sm text-gray-600">Full remote access. Virtual console & media.</p>
        </div>
        
        <!-- Support -->
        <div class="bg-white rounded-xl p-6 border border-gray-200 hover:border-gray-300 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">24/7 Support</h4>
          <p class="text-sm text-gray-600">Remote hands available. 99.99% uptime SLA.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="features" class="py-24 bg-white relative overflow-hidden">
  <div class="container mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-16 max-w-4xl mx-auto">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading mb-6 text-gray-900">
        Why go dedicated?
        <span class="block text-blue-500 mt-2">Control matters.</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        When performance is critical and isolation is non-negotiable, 
        dedicated servers deliver what cloud can't.
      </p>
    </div>
    
    <!-- Features grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      <!-- Predictable Performance -->
      <div class="group relative bg-white rounded-xl border border-gray-200 p-8 hover:border-gray-300 hover:shadow-xl transition-all duration-300">
        <div class="w-14 h-14 rounded-lg bg-gray-100 flex items-center justify-center mb-6 group-hover:bg-gray-200 transition-colors duration-300">
          <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Predictable Performance</h3>
        <p class="text-gray-600 mb-6 leading-relaxed">No noisy neighbors. Your applications get 100% of the CPU, RAM, and disk I/O all the time.</p>
        <div class="space-y-2">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-gray-600">Dedicated CPU cores</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-gray-600">Full memory allocation</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-gray-600">Guaranteed disk IOPS</span>
          </div>
        </div>
      </div>

      <!-- Complete Control -->
      <div class="group relative bg-white rounded-xl border border-gray-200 p-8 hover:border-gray-300 hover:shadow-xl transition-all duration-300">
        <div class="w-14 h-14 rounded-lg bg-gray-100 flex items-center justify-center mb-6 group-hover:bg-gray-200 transition-colors duration-300">
          <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Complete Control</h3>
        <p class="text-gray-600 mb-6 leading-relaxed">Root access to everything. Install any OS, configure any software, optimize any setting.</p>
        <div class="space-y-2">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-gray-600">Full root/admin access</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-gray-600">Custom kernel options</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-gray-600">Any OS or hypervisor</span>
          </div>
        </div>
      </div>

      <!-- Security & Compliance -->
      <div class="group relative bg-white rounded-xl border border-gray-200 p-8 hover:border-gray-300 hover:shadow-xl transition-all duration-300">
        <div class="w-14 h-14 rounded-lg bg-gray-100 flex items-center justify-center mb-6 group-hover:bg-gray-200 transition-colors duration-300">
          <svg class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Security & Compliance</h3>
        <p class="text-gray-600 mb-6 leading-relaxed">Physical isolation meets compliance requirements that shared infrastructure can't.</p>
        <div class="space-y-2">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-gray-600">Physical isolation</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-gray-600">HIPAA/PCI ready</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-gray-600">Private networking</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
