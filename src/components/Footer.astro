---
import { Image } from 'astro:assets';
import logo from '@/assets/nelexa/nelexa-logo.png';

const currentYear = new Date().getFullYear();
---

<footer class="bg-black text-white border-t border-white/10">
  <div class="container mx-auto py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-4">
        <a href="/" class="inline-block mb-6">
          <Image src={logo} alt="Nelexa" class="h-8 w-auto" loading="lazy" />
        </a>
        
        <p class="text-white/60 mb-6 max-w-md text-sm leading-relaxed">
          Enterprise-grade infrastructure solutions for mission-critical applications. 
          Powering businesses worldwide with reliable, secure, and scalable technology.
        </p>
        
        <div class="space-y-2 text-sm text-white/60">
          <div class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-400">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <a href="mailto:sales@nelexa.net" class="hover:text-white transition-colors">sales@nelexa.net</a>
          </div>
          <div class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-400">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Dallas, TX · New York, NY</span>
          </div>
        </div>
        
        <div class="flex space-x-3 mt-6">
          <a href="https://discord.gg/nelexa" target="_blank" rel="noopener noreferrer" aria-label="Discord"
             class="bg-white/5 hover:bg-primary-600 text-white p-2.5 rounded-lg transition-colors duration-300 border border-white/10 hover:border-primary-500">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.317 4.369a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.249a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.249.077.077 0 00-.079-.037 19.736 19.736 0 00-4.885 1.515.07.07 0 00-.032.027C.533 9.045-.32 13.58.099 18.057a.082.082 0 00.031.056 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028 14.09 14.09 0 001.226-1.994.076.076 0 00-.041-.105 13.098 13.098 0 01-1.872-.892.077.077 0 01-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 01.077-.01c3.927 1.793 8.18 1.793 12.061 0a.074.074 0 01.078.009c.12.099.246.198.372.292a.077.077 0 01-.006.127 12.3 12.3 0 01-1.873.892.077.077 0 00-.041.106c.36.699.772 1.363 1.225 1.993a.076.076 0 00.084.028 19.84 19.84 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.548-13.66a.061.061 0 00-.031-.028zM8.02 15.331c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.418 2.157-2.418 1.21 0 2.176 1.095 2.157 2.418 0 1.334-.956 2.419-2.157 2.419zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.418 2.157-2.418 1.21 0 2.176 1.095 2.157 2.418 0 1.334-.946 2.419-2.157 2.419z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <div class="lg:col-span-8">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
          <!-- Services -->
          <div>
            <h3 class="text-xs font-semibold mb-4 text-white uppercase tracking-wider">Services</h3>
            <ul class="space-y-2.5">
              <li><a href="/dedicated" class="text-white/50 hover:text-white text-sm transition-colors">Dedicated Servers</a></li>
              <li><a href="/colocation" class="text-white/50 hover:text-white text-sm transition-colors">Colocation</a></li>
              <li><a href="/hardware" class="text-white/50 hover:text-white text-sm transition-colors">Hardware Solutions</a></li>
              <li><a href="/ip-transit" class="text-white/50 hover:text-white text-sm transition-colors">IP Transit</a></li>
            </ul>
          </div>
          
          <!-- Company -->
          <div>
            <h3 class="text-xs font-semibold mb-4 text-white uppercase tracking-wider">Company</h3>
            <ul class="space-y-2.5">
              <li><a href="/case-studies" class="text-white/50 hover:text-white text-sm transition-colors">Case Studies</a></li>
              <li><a href="/contact" class="text-white/50 hover:text-white text-sm transition-colors">Contact Sales</a></li>
              <li><a href="/locations/dallas" class="text-white/50 hover:text-white text-sm transition-colors">Dallas</a></li>
              <li><a href="/locations/new-york" class="text-white/50 hover:text-white text-sm transition-colors">New York</a></li>
            </ul>
          </div>
          
          <!-- Resources -->
          <div>
            <h3 class="text-xs font-semibold mb-4 text-white uppercase tracking-wider">Resources</h3>
            <ul class="space-y-2.5">
              <li><a href="/contact" class="text-white/50 hover:text-white text-sm transition-colors">Support</a></li>
              <li><a href="https://status.nelexa.net" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white text-sm transition-colors">Status</a></li>
              <li><a href="https://discord.gg/nelexa" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white text-sm transition-colors">Discord</a></li>
              <li><a href="/legal" class="text-white/50 hover:text-white text-sm transition-colors">Legal</a></li>
            </ul>
          </div>
          
          <!-- Legal -->
          <div>
            <h3 class="text-xs font-semibold mb-4 text-white uppercase tracking-wider">Legal</h3>
            <ul class="space-y-2.5">
              <li><a href="/terms-of-service" class="text-white/50 hover:text-white text-sm transition-colors">Terms of Service</a></li>
              <li><a href="/privacy-policy" class="text-white/50 hover:text-white text-sm transition-colors">Privacy Policy</a></li>
              <li><a href="/sla-policy" class="text-white/50 hover:text-white text-sm transition-colors">SLA</a></li>
              <li><a href="/refund-policy" class="text-white/50 hover:text-white text-sm transition-colors">Refund Policy</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="border-t border-white/10 py-6">
    <div class="container mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-3 md:space-y-0 text-white/40 text-xs">
        <p class="leading-none mb-0">&copy; {currentYear} Nelexa, Inc. All rights reserved.</p>
        <p class="leading-none mb-0">Built for mission-critical infrastructure.</p>
      </div>
    </div>
  </div>
</footer>
