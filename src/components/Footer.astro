---
import { Image } from 'astro:assets';
import logo from '@/assets/cits/charged-banner-white-3x-nobg.png';

const currentYear = new Date().getFullYear();
---

<footer class="bg-black text-white">
  <!-- Footer Top Section -->
  <div class="container mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10">
      <!-- Brand Column -->
      <div class="lg:col-span-5">
        <a href="/" class="inline-block mb-6">
          <Image src={logo} alt="Charged IT Solutions" class="h-8 w-auto" loading="lazy" />
        </a>
        
        <p class="text-white/70 mb-8 max-w-md text-sm leading-relaxed">
          Infrastructure that actually works. Support that actually helps. Pricing that actually makes sense. 
          No BS, no surprises, just reliable hosting from people who give a damn.
        </p>
        
        <!-- Social Links -->
        <div class="flex space-x-3">
          <a href="https://x.com/cits_llc" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" 
             class="bg-white/10 hover:bg-white/20 text-white p-2 rounded-lg transition-colors duration-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="currentColor"/>
            </svg>
          </a>
          
          <a href="https://www.linkedin.com/company/charged-it-solutions-llc" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
             class="bg-white/10 hover:bg-white/20 text-white p-2 rounded-lg transition-colors duration-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" fill="currentColor"/>
            </svg>
          </a>
          
          <a href="https://github.com/chargeditsolutionsllc" target="_blank" rel="noopener noreferrer" aria-label="GitHub"
             class="bg-white/10 hover:bg-white/20 text-white p-2 rounded-lg transition-colors duration-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" fill="currentColor"/>
            </svg>
          </a>
          
          <a href="https://discord.chargeditsolutions.com" target="_blank" rel="noopener noreferrer" aria-label="Discord"
             class="bg-white/10 hover:bg-white/20 text-white p-2 rounded-lg transition-colors duration-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M18.93 5.34C17.56 4.71 16.11 4.25 14.59 4C14.42 4.31 14.23 4.72 14.1 5.05C12.5 4.81 10.92 4.81 9.35 5.05C9.22 4.72 9.02 4.31 8.85 4C7.33 4.25 5.88 4.71 4.5 5.34C1.88 9.41 1.13 13.35 1.5 17.25C3.3 18.61 5.05 19.43 6.78 19.97C7.19 19.41 7.56 18.82 7.88 18.19C7.31 17.99 6.77 17.73 6.26 17.44C6.39 17.34 6.52 17.24 6.64 17.13C9.94 18.61 13.53 18.61 16.79 17.13C16.92 17.24 17.05 17.34 17.17 17.44C16.66 17.73 16.12 17.99 15.55 18.19C15.87 18.82 16.24 19.41 16.65 19.97C18.38 19.43 20.13 18.61 21.93 17.25C22.37 12.77 21.21 8.86 18.93 5.34ZM8.36 14.91C7.36 14.91 6.54 14.01 6.54 12.91C6.54 11.81 7.34 10.91 8.36 10.91C9.38 10.91 10.2 11.81 10.18 12.91C10.18 14.01 9.38 14.91 8.36 14.91ZM15.07 14.91C14.07 14.91 13.25 14.01 13.25 12.91C13.25 11.81 14.05 10.91 15.07 10.91C16.09 10.91 16.91 11.81 16.89 12.91C16.89 14.01 16.09 14.91 15.07 14.91Z" fill="currentColor"/>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Navigation Columns -->
      <div class="lg:col-span-7">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          <!-- Company Links -->
          <div>
            <h3 class="text-sm font-semibold mb-4 text-white uppercase tracking-wider">Company</h3>
            <ul class="space-y-3">
              <li>
                <a href="/#about" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  About Us
                </a>
              </li>
              <li>
                <a href="/#contact" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Contact
                </a>
              </li>
              <li>
                <a href="https://status.chargeditsolutions.com" target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Status Page
                </a>
              </li>
              <li>
                <a href="https://lg.chargeditsolutions.com" target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Looking Glass
                </a>
              </li>
            </ul>
          </div>
          
          <!-- Solutions Links -->
          <div>
            <h3 class="text-sm font-semibold mb-4 text-white uppercase tracking-wider">Solutions</h3>
            <ul class="space-y-3">
              <li>
                <a href="/solutions/virtual-machines" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Virtual Machines
                </a>
              </li>
              <li>
                <a href="/solutions/dedicated-metal" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Dedicated Servers
                </a>
              </li>
              <li>
                <a href="/solutions/colocation" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Colocation
                </a>
              </li>
              <li>
                <a href="/solutions/ddos-protection" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  DDoS Protection
                </a>
              </li>
            </ul>
          </div>
          
          <!-- Legal Links -->
          <div>
            <h3 class="text-sm font-semibold mb-4 text-white uppercase tracking-wider">Legal</h3>
            <ul class="space-y-3">
              <li>
                <a href="/terms-of-service" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Terms of Service
                </a>
              </li>
              <li>
                <a href="/privacy-policy" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Privacy Policy
                </a>
              </li>
              <li>
                <a href="/sla-policy" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  SLA Policy
                </a>
              </li>
              <li>
                <a href="/refund-policy" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Refund Policy
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Footer Bottom Section -->
  <div class="border-t border-white/10 py-6">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-3 md:space-y-0">
        <p class="text-white/40 text-xs leading-none mb-0">&copy; {currentYear} Charged IT Solutions LLC. All rights reserved.</p>
        
        <p class="text-white/40 text-xs leading-none mb-0">
          Built with <span class="text-red-500">❤️</span> in Phoenix, Arizona
        </p>
      </div>
    </div>
  </div>
</footer>
