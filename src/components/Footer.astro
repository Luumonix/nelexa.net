---
import { Image } from 'astro:assets';
import logo from '@/assets/nelexa/nelexa-logo.png';

const currentYear = new Date().getFullYear();
---

<footer class="bg-black text-white">
  <!-- Footer Top Section -->
  <div class="container mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10">
      <!-- Brand Column -->
      <div class="lg:col-span-5">
        <a href="/" class="inline-block mb-6">
          <Image src={logo} alt="Nelexa" class="h-8 w-auto nelexa-logo-white" loading="lazy" />
        </a>

        <p class="text-white/70 mb-8 max-w-md text-sm leading-relaxed">
          Enterprise-grade dedicated servers, colocation, IP transit, and hardware solutions — delivered from our Dallas and New York data centers. Mission-critical infrastructure, built to scale.
        </p>

        <!-- Social Links -->
        <div class="flex space-x-3">
          <a href="#" aria-label="X (Twitter)"
             class="bg-white/10 hover:bg-white/20 text-white p-2 rounded-lg transition-colors duration-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="currentColor"/>
            </svg>
          </a>

          <a href="#" aria-label="LinkedIn"
             class="bg-white/10 hover:bg-white/20 text-white p-2 rounded-lg transition-colors duration-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" fill="currentColor"/>
            </svg>
          </a>

          <a href="#" aria-label="GitHub"
             class="bg-white/10 hover:bg-white/20 text-white p-2 rounded-lg transition-colors duration-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.02c-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.23-1.27-5.23-5.67 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.17.92-.25 1.9-.38 2.88-.38.98 0 1.96.13 2.88.38 2.19-1.48 3.15-1.17 3.15-1.17.62 1.59.23 2.76.11 3.05.74.8 1.18 1.82 1.18 3.07 0 4.41-2.69 5.37-5.25 5.66.41.36.77 1.07.77 2.16v3.2c0 .31.21.67.8.56C20.22 21.38 23.5 17.08 23.5 12 23.5 5.73 18.27.5 12 .5z"/>
            </svg>
          </a>

          <a href="#" aria-label="Discord"
             class="bg-white/10 hover:bg-white/20 text-white p-2 rounded-lg transition-colors duration-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.317 4.369a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.249a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.249.077.077 0 00-.079-.037 19.736 19.736 0 00-4.885 1.515.07.07 0 00-.032.027C.533 9.045-.32 13.58.099 18.057a.082.082 0 00.031.056 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028 14.09 14.09 0 001.226-1.994.076.076 0 00-.041-.105 13.098 13.098 0 01-1.872-.892.077.077 0 01-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 01.077-.01c3.927 1.793 8.18 1.793 12.061 0a.074.074 0 01.078.009c.12.099.246.198.372.292a.077.077 0 01-.006.127 12.3 12.3 0 01-1.873.892.077.077 0 00-.041.106c.36.699.772 1.363 1.225 1.993a.076.076 0 00.084.028 19.84 19.84 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.548-13.66a.061.061 0 00-.031-.028zM8.02 15.331c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.418 2.157-2.418 1.21 0 2.176 1.095 2.157 2.418 0 1.334-.956 2.419-2.157 2.419zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.418 2.157-2.418 1.21 0 2.176 1.095 2.157 2.418 0 1.334-.946 2.419-2.157 2.419z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation Columns -->
      <div class="lg:col-span-7">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          <!-- Company Links -->
          <div>
            <h3 class="text-sm font-semibold mb-4 text-white uppercase tracking-wider">Company</h3>
            <ul class="space-y-3">
              <li>
                <a href="/#about" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  About Us
                </a>
              </li>
              <li>
                <a href="/case-studies" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Case Studies
                </a>
              </li>
              <li>
                <a href="/contact" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Contact Sales
                </a>
              </li>
              <li>
                <a href="mailto:sales@nelexa.net" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  sales@nelexa.net
                </a>
              </li>
            </ul>
          </div>

          <!-- Services Links -->
          <div>
            <h3 class="text-sm font-semibold mb-4 text-white uppercase tracking-wider">Services</h3>
            <ul class="space-y-3">
              <li>
                <a href="/dedicated" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Dedicated Servers
                </a>
              </li>
              <li>
                <a href="/colocation" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Colocation
                </a>
              </li>
              <li>
                <a href="/hardware" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Hardware Solutions
                </a>
              </li>
              <li>
                <a href="/ip-transit" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  IP Transit
                </a>
              </li>
            </ul>
          </div>

          <!-- Legal Links -->
          <div>
            <h3 class="text-sm font-semibold mb-4 text-white uppercase tracking-wider">Legal</h3>
            <ul class="space-y-3">
              <li>
                <a href="/terms-of-service" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Terms of Service
                </a>
              </li>
              <li>
                <a href="/privacy-policy" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Privacy Policy
                </a>
              </li>
              <li>
                <a href="/sla-policy" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  SLA Policy
                </a>
              </li>
              <li>
                <a href="/refund-policy" class="text-white/60 hover:text-white text-sm transition-colors duration-300">
                  Refund Policy
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer Bottom Section -->
  <div class="border-t border-white/10 py-6">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-3 md:space-y-0">
        <p class="text-white/40 text-xs leading-none mb-0">&copy; {currentYear} Nelexa, Inc. All rights reserved.</p>

        <p class="text-white/40 text-xs leading-none mb-0">
          Dallas, TX · New York, NY
        </p>
      </div>
    </div>
  </div>
</footer>
