---
import { getImage } from 'astro:assets';
import heroBackground from '@/assets/img/900gb_sas_closeup.jpeg';

const optimizedBackground = await getImage({
  src: heroBackground,
  format: 'webp',
  quality: 80,
  width: 1920
});
---
<section class="hero">
  <div class="hero-background" style={`background-image: url(${optimizedBackground.src});`}>
    <div class="hero-overlay"></div>
  </div>
  
  <div class="container">
    <div class="hero-content">
      <h1>
        <span class="hero-title-line">Enterprise-grade</span>
        <span class="hero-title-line">block storage.</span>
      </h1>
      
      <p class="hero-subtitle">
        High-performance block storage with ZFS redundancy and SSD caching for your
        mission-critical applications and data.
      </p>
      </div>
    </div>
  </div>
  
  <div class="hero-scroll-indicator">
    <a href="#features" aria-label="Scroll to features">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 5V19M12 19L5 12M12 19L19 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    color: var(--color-white);
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    /* background-image set via inline style */
    background-size: cover;
    background-position: center;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--gradient-primary);
    opacity: 0.92;
    z-index: 1;
  }

  .container {
    position: relative;
    z-index: 3;
  }

  .hero-content {
    max-width: 800px;
    padding: 0 var(--spacing-4);
    margin: -5vh auto 0;
    text-align: center;
  }

  .hero h1 {
    font-size: 4rem;
    line-height: 1.1;
    margin-bottom: var(--spacing-8);
    color: var(--color-white);
    font-weight: 800;
  }

  .hero-title-line {
    display: block;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-12);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
  }

  .hero-features {
    display: flex;
    justify-content: center;
    gap: var(--spacing-8);
    margin-top: var(--spacing-8);
  }

  .hero-feature {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .feature-icon {
    font-size: 1.25rem;
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: var(--spacing-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    animation: bounce 2s infinite;
  }

  .hero-scroll-indicator a {
    color: var(--color-white);
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .hero-scroll-indicator a:hover {
    opacity: 1;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateY(0) translateX(-50%);
    }
    40% {
      transform: translateY(-10px) translateX(-50%);
    }
    60% {
      transform: translateY(-5px) translateX(-50%);
    }
  }

  @media (max-width: 1024px) {
    .hero h1 {
      font-size: 3.5rem;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 70vh;
    }

    .hero h1 {
      font-size: 2.75rem;
    }

    .hero-subtitle {
      font-size: 1.125rem;
    }

    .hero-features {
      flex-direction: column;
      align-items: center;
      gap: var(--spacing-4);
    }
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 2.25rem;
    }
  }
</style>
