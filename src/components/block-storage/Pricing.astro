---
---
<section id="pricing" class="section pricing-section">
  <div class="container">
    <div class="section-title">
      <h2>Simple, Transparent Pricing</h2>
      <p>Affordable block storage with no hidden fees or setup costs</p>
    </div>
    
    <div class="pricing-container">
      <div class="pricing-card">
        <div class="pricing-header">
          <h3>Block Storage</h3>
          <div class="pricing-badge">Phoenix, AZ</div>
        </div>
        
        <div class="pricing-price">
          <span class="price-amount">$4.50</span>
          <span class="price-period">per TB / month</span>
        </div>
        
        <div class="pricing-features">
          <ul>
            <li>
              <svg class="feature-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 13L9 17L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              ZFS redundancy with multiple 18TB drive arrays
            </li>
            <li>
              <svg class="feature-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 13L9 17L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Enterprise SSD caching for high performance
            </li>
            <li>
              <svg class="feature-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 13L9 17L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              No setup fee or NRC
            </li>
            <li>
              <svg class="feature-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 13L9 17L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Available as an add-on with:
            </li>
          </ul>
          
          <div class="compatible-services">
            <div class="compatible-service">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M21 16V7.2C21 6.0799 21 5.51984 20.782 5.09202C20.5903 4.71569 20.2843 4.40973 19.908 4.21799C19.4802 4 18.9201 4 17.8 4H6.2C5.07989 4 4.51984 4 4.09202 4.21799C3.71569 4.40973 3.40973 4.71569 3.21799 5.09202C3 5.51984 3 6.0799 3 7.2V16.8C3 17.9201 3 18.4802 3.21799 18.908C3.40973 19.2843 3.71569 19.5903 4.09202 19.782C4.51984 20 5.0799 20 6.2 20H17.8C18.9201 20 19.4802 20 19.908 19.782C20.2843 19.5903 20.5903 19.2843 20.782 18.908C21 18.4802 21 17.9201 21 16.8V16ZM21 16H18.5C16.567 16 15 17.567 15 19.5M7 8H17M7 12H17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>Cloud Compute</span>
            </div>
            <div class="compatible-service">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 6L8 4M8 4L10 6M8 4V20M14 18L16 20M16 20L18 18M16 20V4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>Dedicated Metal</span>
            </div>
            <div class="compatible-service">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 6C4 4.89543 4.89543 4 6 4H18C19.1046 4 20 4.89543 20 6V9C20 10.1046 19.1046 11 18 11H6C4.89543 11 4 10.1046 4 9V6Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M4 14C4 12.8954 4.89543 12 6 12H18C19.1046 12 20 12.8954 20 14V17C20 18.1046 19.1046 19 18 19H6C4.89543 19 4 18.1046 4 17V14Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="7.5" cy="7.5" r="0.5" fill="currentColor" stroke="currentColor" stroke-width="0.5"/>
                <circle cx="7.5" cy="15.5" r="0.5" fill="currentColor" stroke="currentColor" stroke-width="0.5"/>
              </svg>
              <span>Colocation</span>
            </div>
          </div>
        </div>
        
        <div class="pricing-cta">
          <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-semibold text-lg rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-blue-500/25 hover:scale-[1.02] w-full">Get Started</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    background-color: var(--color-white);
    padding: var(--spacing-24) 0;
    position: relative;
  }

  .pricing-container {
    display: flex;
    justify-content: center;
    margin-top: var(--spacing-12);
  }

  .pricing-card {
    background-color: var(--color-white);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    transition: all 0.3s ease;
    width: 100%;
    max-width: 600px;
    border: 1px solid var(--color-gray-200);
  }

  .pricing-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-xl);
  }

  .pricing-header {
    padding: var(--spacing-8);
    background: var(--gradient-primary);
    color: var(--color-white);
    text-align: center;
    position: relative;
  }

  .pricing-header h3 {
    margin-bottom: var(--spacing-2);
    color: var(--color-white);
    font-size: 1.75rem;
  }

  .pricing-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: var(--border-radius-md);
    font-size: 0.875rem;
    font-weight: 600;
    margin-top: var(--spacing-2);
  }

  .pricing-price {
    padding: var(--spacing-8) var(--spacing-4);
    text-align: center;
    border-bottom: 1px solid var(--color-gray-200);
  }

  .price-amount {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    font-family: 'Montserrat', sans-serif;
  }

  .price-period {
    display: block;
    font-size: 1rem;
    color: var(--color-gray-500);
    margin-top: var(--spacing-2);
  }

  .pricing-features {
    padding: var(--spacing-8);
  }

  .pricing-features ul {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--spacing-6) 0;
  }

  .pricing-features li {
    display: flex;
    align-items: flex-start;
    margin-bottom: var(--spacing-4);
    color: var(--color-gray-700);
    line-height: 1.5;
  }

  .feature-icon {
    margin-right: var(--spacing-3);
    flex-shrink: 0;
    margin-top: 0.25rem;
    color: var(--color-secondary);
  }

  .compatible-services {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-4);
    justify-content: center;
    margin-top: var(--spacing-6);
  }

  .compatible-service {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-2);
    padding: var(--spacing-4);
    border-radius: var(--border-radius-md);
    background-color: var(--color-gray-100);
    width: calc(33.333% - var(--spacing-3));
    text-align: center;
  }

  .compatible-service svg {
    color: var(--color-secondary);
    margin-bottom: var(--spacing-1);
  }

  .compatible-service span {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-gray-700);
  }

  .pricing-cta {
    padding: var(--spacing-6) var(--spacing-8) var(--spacing-8);
    text-align: center;
    border-top: 1px solid var(--color-gray-200);
  }

  @media (max-width: 768px) {
    .pricing-section {
      padding: var(--spacing-16) 0;
    }
    
    .pricing-card {
      max-width: 100%;
    }
    
    .compatible-service {
      width: 100%;
    }
    
    .compatible-services {
      flex-direction: column;
      gap: var(--spacing-3);
    }
  }
</style>
