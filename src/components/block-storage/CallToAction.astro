---
---

<section class="relative py-24 lg:py-32 overflow-hidden">
  <!-- Background with subtle gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-950 to-black"></div>
  
  <!-- Subtle storage-themed accent -->
  <div class="absolute inset-0 opacity-[0.03]">
    <div class="absolute top-1/4 right-1/3 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/2 left-1/4 w-96 h-96 bg-cyan-500 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto">
      <!-- Main content -->
      <div class="text-center space-y-8">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading text-white leading-tight">
          Scale storage instantly.
          <span class="block text-3xl md:text-4xl lg:text-5xl mt-3 font-normal text-blue-400">
            Pay only for what you use.
          </span>
        </h2>
        
        <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
          Add terabytes in seconds. Enterprise NVMe performance, triple replication, 
          and seamless expansion. Your data grows, your storage follows—simple as that.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
          <a 
            href="https://client.chargeditsolutions.com/store/block-storage"
            class="group inline-flex items-center justify-center gap-3 px-8 py-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-semibold text-lg rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-blue-500/25 hover:scale-[1.02]"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
            </svg>
            <span>Add Storage</span>
          </a>
          
          <a 
            href="mailto:storage@chargeditsolutions.com?subject=Block Storage Inquiry"
            class="group inline-flex items-center justify-center gap-3 px-8 py-4 bg-gray-800 text-white font-semibold text-lg rounded-lg border border-gray-700 transition-all duration-300 hover:bg-gray-700 hover:border-gray-600"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            <span>Volume Planning</span>
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="pt-8 flex flex-wrap items-center justify-center gap-8 text-sm text-gray-400">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>99.999% durability</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            <span>NVMe performance</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
            </svg>
            <span>Live resize</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
