---
---

<section class="relative py-24 lg:py-32 overflow-hidden">
  <!-- Background with subtle gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-950 to-black"></div>
  
  <!-- Subtle managed services-themed accent -->
  <div class="absolute inset-0 opacity-[0.03]">
    <div class="absolute top-1/3 left-1/2 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/2 right-1/4 w-96 h-96 bg-cyan-500 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto">
      <!-- Main content -->
      <div class="text-center space-y-8">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading text-white leading-tight">
          Focus on growth.
          <span class="block text-3xl md:text-4xl lg:text-5xl mt-3 font-normal text-blue-400">
            We'll handle the ops.
          </span>
        </h2>
        
        <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
          From monitoring to migrations, backups to optimizations—let our team become your team. 
          Enterprise expertise without enterprise overhead. Coming soon.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
          <a 
            href="mailto:managed@chargeditsolutions.com?subject=Managed Services Early Access"
            class="group inline-flex items-center justify-center gap-3 px-8 py-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-semibold text-lg rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-blue-500/25 hover:scale-[1.02]"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            <span>Get Early Access</span>
          </a>
          
          <a 
            href="https://client.chargeditsolutions.com/store"
            class="group inline-flex items-center justify-center gap-3 px-8 py-4 bg-gray-800 text-white font-semibold text-lg rounded-lg border border-gray-700 transition-all duration-300 hover:bg-gray-700 hover:border-gray-600"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
            <span>Explore Services</span>
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="pt-8 flex flex-wrap items-center justify-center gap-8 text-sm text-gray-400">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>24/7 monitoring</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>15-min response SLA</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <span>Expert team</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
