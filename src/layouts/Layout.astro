---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import StructuredData from '../components/SEO/StructuredData.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	ogImage?: string;
	structuredData?: {
		type?: 'organization' | 'service' | 'localbusiness' | 'breadcrumb';
		data?: any;
	};
	noindex?: boolean;
}

const { 
	title = "Nelexa — Enterprise Infrastructure Solutions",
	description = "Nelexa delivers enterprise-grade dedicated servers, colocation, IP transit, and hardware solutions from our Dallas and New York data centers. Mission-critical infrastructure, built to scale.",
	keywords = "dedicated servers, colocation, IP transit, hardware solutions, enterprise infrastructure, Dallas data center, New York data center, NYC colocation, Dallas colocation, bare metal, enterprise hosting, HPC servers, AMD Ryzen servers, Intel Xeon servers, clean transit, DDoS protected transit, rack servers, blade servers, storage arrays, Nelexa",
	ogImage = "/og-image.png",
	structuredData,
	noindex = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Enhanced title for better SEO
const fullTitle = title.includes('Nelexa') ? title : `${title} | Nelexa`;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Favicons -->
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
		<link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		
		<title>{fullTitle}</title>
		
		<!-- SEO Meta Tags -->
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content="Elcro Digital Services, LLC dba Nelexa Networks" />
		<link rel="canonical" href={canonicalURL} />
		
		<meta name="generator" content={Astro.generator} />
		<meta name="language" content="English" />
		<meta name="distribution" content="global" />
		<meta name="rating" content="general" />
		
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(ogImage, Astro.site)} />
		<meta property="og:image:alt" content="Nelexa — Enterprise Infrastructure Solutions" />
		<meta property="og:site_name" content="Nelexa" />
		<meta property="og:locale" content="en_US" />
		
		<meta name="theme-color" content="#7C3AED" />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={fullTitle} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(ogImage, Astro.site)} />
		
		<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
		
		<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"} />
		<meta name="googlebot" content={noindex ? "noindex, nofollow" : "index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"} />
		
		<!-- Geo Tags — Dallas, TX & New York, NY -->
		<meta name="geo.region" content="US-TX" />
		<meta name="geo.placename" content="Dallas" />
		<meta name="geo.region" content="US-NY" />
		<meta name="geo.placename" content="New York" />
		
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		
		<link rel="preload" href="https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIa0ZL7.woff2" as="font" type="font/woff2" crossorigin />
		
		<link 
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" 
			rel="stylesheet"
		/>
		
		{structuredData && <StructuredData type={structuredData.type} data={structuredData.data} />}
	</head>
	<body>
		<Navbar />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
